        fi
    }

    fn abs self:int -> int {
        if 0 self < then 0 self - else self fi
    }

    fn min self:int other:int -> int {
        if other self < then self else other fi
    }

    fn max self:int other:int -> int {
        if self other < then self else other fi
    }

    fn clamp self:int lo:int hi:int -> int {
        if lo self < then lo
    elif self hi < then hi
else self fi
}

