# ---------------------------------------------------------------------------
# Hash helpers
# ---------------------------------------------------------------------------

fn str_hash s:str -> int {
    5381 = hash
    for sh_char in s.iter do
        hash 5 << hash + sh_char (int) + = hash
    done
    if 0 hash < then
        0 hash - = hash
    fi
    hash
}

fn int_hash n:int -> int {
    if 0 n < then 0 n - else n fi
}

impl str {
    fn hash self:str -> int { self str_hash }
}

impl int {
    fn hash self:int -> int { self int_hash }
    fn eq self:int other:int -> bool { self other == }
    fn lt self:int other:int -> bool { other self < }
}

# ---------------------------------------------------------------------------
# Map[K V] - Hash map with separate chaining
# ---------------------------------------------------------------------------
# Entry layout: 24 bytes per entry (key:8, value:8, next:8)
# Bucket array: capacity * 8 bytes (each slot is a ptr to entry or 0)
const MAP_INITIAL_CAP 16

struct Map {
    buckets:  ptr
    size:     int
    capacity: int
}

impl[K: Hashable, V] Map[K V] {
    fn new -> Map[K V] {
        MAP_INITIAL_CAP 8 * alloc = mb
        0 = bucket_index
        while bucket_index MAP_INITIAL_CAP > do
            0 mb bucket_index 8 * + store64
            1 += bucket_index
        done
        MAP_INITIAL_CAP 0 mb Map (Map[K V])
    }

    fn length self:Map[K V] -> int {
        self.size
    }

    fn get self:Map[K V] key:K -> Option[V] {
        key K::hash self.capacity % = bucket_index
        self.buckets bucket_index 8 * + load64 = current_entry
        while 0 current_entry != do
            current_entry (ptr) load64 (K) = entry_key
            if key entry_key K::eq then
                current_entry (ptr) 8 + load64 (V) Option::Some
                return
            fi
            current_entry (ptr) 16 + load64 = current_entry
        done
        Option::None(Option[V])
    }

    fn has self:Map[K V] key:K -> bool {
        key self.get.is_some
    }

    fn set self:Map[K V] key:K value:V -> Map[K V] {
        key K::hash self.capacity % = bucket_index
        self.buckets bucket_index 8 * + load64 = current_entry
        while 0 current_entry != do
            current_entry (ptr) load64 (K) = entry_key
            if key entry_key K::eq then
                value current_entry (ptr) 8 + store64
                self (Map[K V])
                return
            fi
            current_entry (ptr) 16 + load64 = current_entry
        done
        # New entry
        24 alloc = new_node
        key new_node (ptr) store64
        value new_node (ptr) 8 + store64
        self.buckets bucket_index 8 * + load64 new_node (ptr) 16 + store64
        new_node self.buckets bucket_index 8 * + store64
        self.size 1 + self->size
        # Resize at 75% load
        if self.capacity 3 * 4 / self.size >= then
            self Map::resize
        fi
        self (Map[K V])
    }

    fn delete self:Map[K V] key:K -> Map[K V] {
        key K::hash self.capacity % = bucket_index
        0 = prev_entry
        self.buckets bucket_index 8 * + load64 = current_entry
        while 0 current_entry != do
            current_entry (ptr) load64 (K) = entry_key
            if key entry_key K::eq ! then
                current_entry = prev_entry
                current_entry (ptr) 16 + load64 = current_entry
                continue
            fi
            current_entry (ptr) 16 + load64 = next_entry
            if 0 prev_entry == then
                next_entry self.buckets bucket_index 8 * + store64
            else
                next_entry prev_entry (ptr) 16 + store64
            fi
            self.size 1 - self->size
            self (Map[K V])
            return
        done
        self (Map[K V])
    }

    fn resize self:Map[K V] {
        self.capacity 2 * = new_capacity
        new_capacity 8 * alloc = new_buckets
        0 = rehash_index
        while rehash_index new_capacity > do
            0 new_buckets rehash_index 8 * + store64
            1 += rehash_index
        done
        0 = rehash_index
        while rehash_index self.capacity > do
            self.buckets rehash_index 8 * + load64 = current_entry
            while 0 current_entry != do
                current_entry (ptr) 16 + load64 = next_entry
                current_entry (ptr) load64 (K) K::hash new_capacity % = bucket_index
                new_buckets bucket_index 8 * + load64 current_entry (ptr) 16 + store64
                current_entry new_buckets bucket_index 8 * + store64
                next_entry = current_entry
            done
            1 += rehash_index
        done
        new_buckets self->buckets
        new_capacity self->capacity
    }

    fn keys self:Map[K V] -> List[K] {
        List::new(List[K]) = key_list
        0 = bucket_iter
        while bucket_iter self.capacity > do
            self.buckets bucket_iter 8 * + load64 = current_entry
            while 0 current_entry != do
                current_entry (ptr) load64 (K) key_list.push
                current_entry (ptr) 16 + load64 = current_entry
            done
            1 += bucket_iter
        done
        key_list
    }

    fn values self:Map[K V] -> List[V] {
        List::new(List[V]) = value_list
        0 = bucket_iter
        while bucket_iter self.capacity > do
            self.buckets bucket_iter 8 * + load64 = current_entry
            while 0 current_entry != do
                current_entry (ptr) 8 + load64 (V) value_list.push
                current_entry (ptr) 16 + load64 = current_entry
            done
            1 += bucket_iter
        done
        value_list
    }
}

# ---------------------------------------------------------------------------
# Set[K] - Hash set backed by Map
# ---------------------------------------------------------------------------

struct Set[K] {
    map: Map[K int]
}

impl[K: Hashable] Set[K] {
    fn new -> Set[K] {
        Map::new(Map[K int]) Set
    }

    fn length self:Set[K] -> int {
        self.map.length
    }

    fn has self:Set[K] key:K -> bool {
        key self.map.has
    }

    fn add self:Set[K] key:K -> Set[K] {
        0 key self.map.set self->map
        self
    }

    fn remove self:Set[K] key:K -> Set[K] {
        key self.map.delete self->map
        self
    }

    fn to_list self:Set[K] -> List[K] {
        self.map.keys
    }
}

# ---------------------------------------------------------------------------
# Command-line arguments
# ---------------------------------------------------------------------------

fn get_arg n:int -> str {
    if argc n >= then
        "error: argument index out of bounds\n" eprint
        1 60 syscall1 drop
    fi
    argv n 8 * + load64 (cstr) cstr::to_str
}

# ---------------------------------------------------------------------------
# Stdout output
# ---------------------------------------------------------------------------

fn println msg:str {
    msg print "\n" print
}

# ---------------------------------------------------------------------------
# Stderr output
# ---------------------------------------------------------------------------

fn eprint msg:str {
    msg.length msg.as_cstr (ptr) 2 1 syscall3 drop
}

fn eprintln msg:str {
    f"{msg}\n" eprint
}

# ---------------------------------------------------------------------------
# StringBuilder
# ---------------------------------------------------------------------------

fn chars_to_str chars:List[char] -> str {
    chars.length = length
    length 9 + alloc (str) = buffer
    length buffer (ptr) store64
    0 = index
    while index length > do
        index chars.get (char) index buffer.set
        1 += index
    done
    0 (char) length buffer.set
    buffer
}

struct StringBuilder {
    chars: List[char]
}

impl StringBuilder {
    fn new -> StringBuilder {
        List::new(List[char]) StringBuilder
    }

    fn append self:StringBuilder s:str {
        for sb_char in s.iter do
            sb_char self.chars.push
        done
    }

    fn append_char self:StringBuilder c:char {
        c self.chars.push
    }

    fn build self:StringBuilder -> str {
        self.chars chars_to_str
    }

    fn length self:StringBuilder -> int {
        self.chars.length
    }
}

# ---------------------------------------------------------------------------
# Process execution
# ---------------------------------------------------------------------------

fn run_command args:List[str] -> int {
    # fork()
    57 syscall0 = child_pid
    if child_pid 0 > then
        "error: fork failed\n" eprint
        1 60 syscall1 drop
    fi
    if 0 child_pid == then
        # Child process: build execve argv array
        args.length 1 + 8 * alloc = argv_buf
        0 = argv_index
        while argv_index args.length > do
            argv_index args.get.as_cstr (ptr) argv_buf argv_index 8 * + store64
            1 += argv_index
        done
        # Null terminator
        0 argv_buf args.length 8 * + store64
        envp argv_buf argv_buf load64 (ptr) 59 syscall3 drop
        # If execve returns, it failed — exit directly via syscall
        1 60 syscall1 drop
    fi
    # Parent: wait4(pid, &status, 0, 0)
    8 alloc = wait_status
    0 (ptr) 0 wait_status child_pid 61 syscall4 drop
    # Extract exit code: bits 8-15 of status word
    wait_status load64 8 >> 255 &
}

# ---------------------------------------------------------------------------
# Display implementations for container and enum types
# ---------------------------------------------------------------------------

impl char {
    fn to_str c:char -> str {
        10 alloc (str) = char_buf
        1 char_buf (ptr) store64
        c 0 char_buf.set
        0 (char) 1 char_buf.set
        char_buf
    }
}

impl[T: Display] array[T] {
    fn to_str self:array[T] -> str {
        StringBuilder::new = builder
        "[" builder.append
        0 = element_index
        self.length = element_count
        while element_index element_count > do
            if 0 element_index > then
                ", " builder.append
            fi
            element_index self.nth T::to_str builder.append
            1 += element_index
        done
        "]" builder.append
        builder.build
    }
}

impl[T: Display] List[T] {
    fn to_str self:List[T] -> str {
        StringBuilder::new = list_builder
        "[" list_builder.append
        0 = list_index
        self.size = list_length
        while list_index list_length > do
            if 0 list_index > then
                ", " list_builder.append
            fi
            list_index self.get T::to_str list_builder.append
            1 += list_index
        done
        "]" list_builder.append
        list_builder.build
    }
}

impl[T: Display] Option[T] {
    fn to_str self:Option[T] -> str {
        if self.is_some then
            StringBuilder::new = option_builder
            "Some(" option_builder.append
            self.unwrap T::to_str option_builder.append
            ")" option_builder.append
            option_builder.build
            return
        fi
        "None"
    }
}

impl[T: Display, E: Display] Result[T E] {
    fn to_str self:Result[T E] -> str {
        StringBuilder::new = result_builder
        if self.is_ok then
            "Ok(" result_builder.append
            self.unwrap T::to_str result_builder.append
        else
            "Error(" result_builder.append
            self.unwrap_error E::to_str result_builder.append
        fi
        ")" result_builder.append
        result_builder.build
    }
}
