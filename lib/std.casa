    }

    fn filter self:self f:fn[T -> bool] -> Iter[T] {
        8 alloc = st
        self st store64
        Option::None(Option[T]) = none
        {
            while true do
                st load64 (self).next = opt
                if opt.is_none then
                    none return
                fi
                opt.unwrap = elem
                if elem f exec then
                    elem Option::Some return
                fi
            done
            none
        } (ptr) Iter (Iter[T])
    }

    fn fold [U] self:self acc:U f:fn[U T -> U] -> U {
        for elem in self do
            elem acc f exec = acc
        done
        acc
    }

    fn count self:self -> int {
        0 = n
        for elem in self do
            1 += n
        done
        n
    }

    fn any self:self f:fn[T -> bool] -> bool {
        for elem in self do
            if elem f exec then true return fi
        done
        false
    }

    fn all self:self f:fn[T -> bool] -> bool {
        for elem in self do
            if elem f exec ! then false return fi
        done
        true
    }

    fn find self:self f:fn[T -> bool] -> Option[T] {
        for elem in self do
            if elem f exec then elem Option::Some return fi
        done
        Option::None(Option[T])
    }

