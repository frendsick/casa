# Logging library for Casa programs.
#
# Provides leveled logging to stderr with a configurable global log level.
# Messages above the current level (more verbose) are suppressed.
#
# Usage:
#   import "../lib/log.casa"
#   LogLevel::Info log_set_level
#   "starting up" log_info
#   "something odd" log_warning

import "std.casa"


# ---------------------------------------------------------------------------
# Log levels (higher ordinal = more verbose)
# ---------------------------------------------------------------------------

enum LogLevel {
    Error
    Warning
    Info
    Debug
}


# ---------------------------------------------------------------------------
# Global state
# ---------------------------------------------------------------------------

LogLevel::Warning = LOG_LEVEL


# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

fn log_set_level level:LogLevel {
    level = LOG_LEVEL
}


# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

fn log_level_to_str level:LogLevel -> str {
    level match
        LogLevel::Error   => "ERROR"
        LogLevel::Warning => "WARNING"
        LogLevel::Info    => "INFO"
        LogLevel::Debug   => "DEBUG"
    end
}

fn log_print level:LogLevel message:str {
    if level (int) LOG_LEVEL (int) >= then
        level log_level_to_str = level_str
        f"[{level_str}] {message}" eprintln
    fi
}


# ---------------------------------------------------------------------------
# Logging functions
# ---------------------------------------------------------------------------

fn log_error message:str {
    message LogLevel::Error log_print
}

fn log_warning message:str {
    message LogLevel::Warning log_print
}

fn log_info message:str {
    message LogLevel::Info log_print
}

fn log_debug message:str {
    message LogLevel::Debug log_print
}
