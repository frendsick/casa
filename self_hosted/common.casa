# ============================================================================
# Print intrinsic dispatch names
# ============================================================================

fn print_intrinsic_name name:str -> str {
    if "print_int" name == then "print_int"
    elif "print_str" name == then "print_str"
    elif "print_bool" name == then "print_bool"
    elif "print_char" name == then "print_char"
    elif "print_cstr" name == then "print_cstr"
    else ""
    fi
}

fn print_opkind_for_name name:str -> int {
    if "print_int" name == then OpKind::OpPrintInt (int)
    elif "print_str" name == then OpKind::OpPrintStr (int)
    elif "print_bool" name == then OpKind::OpPrintBool (int)
    elif "print_char" name == then OpKind::OpPrintChar (int)
    elif "print_cstr" name == then OpKind::OpPrintCstr (int)
    else 0 1 -
    fi
}

# ============================================================================
# List helpers for variables
# ============================================================================

fn variable_list_contains vars:List[Variable] name:str -> bool {
    0 = vlc_i
    while vlc_i vars .length > do
        if name vlc_i vars .get Variable::name == then
            true return
        fi
        1 += vlc_i
    done
    false
}

fn variable_list_index vars:List[Variable] name:str -> int {
    0 = vli_i
    while vli_i vars .length > do
        if name vli_i vars .get Variable::name == then
            vli_i return
        fi
        1 += vli_i
    done
    0 1 -
}

fn string_list_contains items:List[str] value:str -> bool {
    0 = slc_i
    while slc_i items .length > do
        if value slc_i items .get == then
            true return
        fi
        1 += slc_i
    done
    false
}

fn string_list_index items:List[str] value:str -> int {
    0 = sli_i
    while sli_i items .length > do
        if value sli_i items .get == then
            sli_i return
        fi
        1 += sli_i
    done
    0 1 -
}
