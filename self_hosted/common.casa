# ============================================================================
# Core data structures
# ============================================================================

struct Span {
    offset: int
    length: int
}

struct Location {
    file: str
    span: Span
}

fn make_location file:str offset:int length:int -> Location {
    length offset Span file Location
}

fn empty_location -> Location {
    0 0 Span "" Location
}

struct Token {
    value:    str
    kind:     int
    location: Location
}

fn make_token value:str kind:int location:Location -> Token {
    location kind value Token
}

# ============================================================================
# Op value types
#
# Since Casa does not have union types, Op values are stored as int (ptr).
# The OpKind determines how to interpret the value:
#   - PUSH_INT, PUSH_CHAR, FSTRING_CONCAT: value is the integer directly
#   - PUSH_BOOL: value is 0 or 1
#   - PUSH_STR, FN_CALL, FN_PUSH, etc.: value is a ptr to a str
#   - PUSH_ENUM_VARIANT, IS_CHECK: value is a ptr to EnumVariant
#   - MATCH_ARM: value is a ptr to EnumVariant, StructPattern, or LiteralPattern
#   - STRUCT_NEW: value is a ptr to CasaStruct
#   - STRUCT_LITERAL: value is a ptr to StructLiteral
#   - PUSH_ARRAY: value is a ptr to List[Op]
#   - Control flow / intrinsics: value unused (0)
# ============================================================================

struct Op {
    value:               int
    kind:                int
    location:            Location
    type_annotation:     str
    deferred_return_type: str
}

fn make_op value:int kind:int location:Location -> Op {
    "" "" location kind value Op
}

fn make_op_str value:str kind:int location:Location -> Op {
    "" "" location kind value (int) Op
}

fn make_op_annotated value:int kind:int location:Location annotation:str -> Op {
    "" annotation location kind value Op
}

fn op_str_value op:Op -> str {
    op Op::value (str)
}

fn op_int_value op:Op -> int {
    op Op::value
}

# ============================================================================
# Instruction
# ============================================================================

struct Inst {
    kind:     int
    int_arg:  int
    str_arg:  str
}

fn make_inst kind:int -> Inst {
    "" 0 kind Inst
}

fn make_inst_int kind:int arg:int -> Inst {
    "" arg kind Inst
}

fn make_inst_str kind:int arg:str -> Inst {
    arg 0 kind Inst
}

# ============================================================================
# Function signature types
# ============================================================================

struct Parameter {
    typ:  str
    name: str
}

fn make_param typ:str -> Parameter {
    "" typ Parameter
}

fn make_named_param typ:str name:str -> Parameter {
    name typ Parameter
}

struct Signature {
    parameters:   List[Parameter]
    return_types: List[str]
    type_vars:    Set[str]
    trait_bounds:  Map[str str]
}

fn empty_signature -> Signature {
    Map::new (Map[str str])
    Set::new (Set[str])
    List::new (List[str])
    List::new (List[Parameter])
    Signature
}

fn make_signature params:List[Parameter] returns:List[str] -> Signature {
    Map::new (Map[str str])
    Set::new (Set[str])
    returns
    params
    Signature
}

# ============================================================================
# Variable, Member
# ============================================================================

struct Variable {
    name: str
    typ:  str
}

fn make_variable name:str -> Variable {
    "" name Variable
}

struct ResolvedVariable {
    get_kind: int
    set_kind: int
    index:    int
}

struct Member {
    name: str
    typ:  str
}

# ============================================================================
# Enum-related types
# ============================================================================

struct EnumVariant {
    enum_name:    str
    variant_name: str
    ordinal:      int
    bindings:     List[str]
}

fn make_enum_variant enum_name:str variant_name:str ordinal:int -> EnumVariant {
    List::new (List[str]) ordinal variant_name enum_name EnumVariant
}

fn is_wildcard_variant variant:EnumVariant -> bool {
    "_" variant EnumVariant::variant_name ==
}

struct StructLiteral {
    struct_name: str
    field_order: List[str]
}

struct StructPattern {
    struct_name: str
    bindings:    Map[str str]
}

fn is_wildcard_struct_pattern pattern:StructPattern -> bool {
    false
}

struct LiteralPattern {
    value: int
    typ:   str
    raw:   str
}

fn is_wildcard_literal_pattern pattern:LiteralPattern -> bool {
    false
}

# ============================================================================
# Enum definition
# ============================================================================

struct CasaEnum {
    name:          str
    variants:      List[str]
    location:      Location
    variant_types: Map[str List[str]]
    type_vars:     List[str]
}

fn has_inner_values casa_enum:CasaEnum -> bool {
    0 = hiv_i
    while hiv_i casa_enum CasaEnum::variant_types .keys .length > do
        hiv_i casa_enum CasaEnum::variant_types .keys .get = hiv_key
        if hiv_key casa_enum CasaEnum::variant_types .get .unwrap .length 0 != then
            true return
        fi
        1 += hiv_i
    done
    false
}

# ============================================================================
# Struct definition
# ============================================================================

struct CasaStruct {
    name:      str
    members:   List[Member]
    location:  Location
    type_vars: List[str]
}

# ============================================================================
# Trait definition
# ============================================================================

struct TraitMethod {
    name:      str
    signature: Signature
}

struct CasaTrait {
    name:     str
    methods:  List[TraitMethod]
    location: Location
}

# ============================================================================
# Function definition
# ============================================================================

struct Function {
    name:                str
    ops:                 List[Op]
    location:            Location
    signature:           Signature
    bytecode:            List[Inst]
    is_used:             int
    is_typechecked:      int
    variables:           List[Variable]
    captures:            List[Variable]
    has_deferred_methods: int
}

fn make_function name:str ops:List[Op] location:Location -> Function {
    0 List::new (List[Variable]) List::new (List[Variable]) 0 0 List::new (List[Inst]) empty_signature location ops name Function
}

fn make_function_with_sig name:str ops:List[Op] location:Location sig:Signature -> Function {
    0 List::new (List[Variable]) List::new (List[Variable]) 0 0 List::new (List[Inst]) sig location ops name Function
}

# ============================================================================
# Program (compilation output)
# ============================================================================

struct Program {
    bytecode:        List[Inst]
    functions:       Map[str List[Inst]]
    strings:         List[str]
    globals_count:   int
    constants_count: int
}

# ============================================================================
# Constants
# ============================================================================

"_start" = GLOBAL_SCOPE_LABEL
"any" = ANY_TYPE
"_" = MATCH_WILDCARD
"self" = TRAIT_SELF_TYPE

# ============================================================================
# Type utility functions
# ============================================================================

fn extract_generic_base typ:str -> Option[str] {
    # For 'array[int]' returns 'array', for 'List[int]' returns 'List'.
    # Returns None for fn types and non-parameterized types.
    typ "[" str::find = egb_bracket
    if 0 egb_bracket <= then
        Option::None (Option[str])
        return
    fi
    if typ "]" str::ends_with ! then
        Option::None (Option[str])
        return
    fi
    typ 0 egb_bracket str::substring = egb_base
    if "fn" egb_base == then
        Option::None (Option[str])
    else
        egb_base Option::Some
    fi
}

fn extract_generic_inner typ:str -> Option[str] {
    # For 'array[int]' returns 'int'.
    typ extract_generic_base = egi_base_opt
    if egi_base_opt .is_none then
        Option::None (Option[str])
        return
    fi
    egi_base_opt .unwrap = egi_base
    typ .length egi_base .length - 2 - = egi_inner_len
    typ egi_base .length 1 + egi_inner_len str::substring Option::Some
}

fn split_type_tokens s:str -> List[str] {
    # Split a space-separated type string into tokens, respecting brackets.
    List::new (List[str]) = stt_tokens
    StringBuilder::new = stt_current
    0 = stt_depth
    0 = stt_i
    while stt_i s .length > do
        stt_i s .at = stt_ch
        if '[' stt_ch == then
            1 += stt_depth
            stt_ch stt_current .append_char
        elif ']' stt_ch == then
            stt_depth 1 - = stt_depth
            stt_ch stt_current .append_char
        elif ' ' stt_ch == 0 stt_depth == && then
            if 0 stt_current .length != then
                stt_current .build stt_tokens .push
                StringBuilder::new = stt_current
            fi
        else
            stt_ch stt_current .append_char
        fi
        1 += stt_i
    done
    if 0 stt_current .length != then
        stt_current .build stt_tokens .push
    fi
    stt_tokens
}

fn extract_generic_params typ:str -> Option[List[str]] {
    # For 'Map[str int]' returns ['str', 'int'].
    typ extract_generic_base = egp_base_opt
    if egp_base_opt .is_none then
        Option::None (Option[List[str]])
        return
    fi
    egp_base_opt .unwrap = egp_base
    typ .length egp_base .length - 2 - = egp_inner_len
    typ egp_base .length 1 + egp_inner_len str::substring split_type_tokens Option::Some
}

fn is_fn_type typ:str -> bool {
    "fn" typ == typ "fn[" str::starts_with ||
}

fn extract_fn_signature_str typ:str -> Option[str] {
    # Returns None for bare 'fn' or non-fn types.
    if typ "fn[" str::starts_with ! then
        Option::None (Option[str])
        return
    fi
    if typ "]" str::ends_with ! then
        Option::None (Option[str])
        return
    fi
    # Extract between fn[ and ]
    typ .length 4 - = efs_len
    typ 3 efs_len str::substring Option::Some
}

fn is_builtin_type typ:str -> bool {
    "int" typ ==
    "bool" typ == ||
    "char" typ == ||
    "cstr" typ == ||
    "str" typ == ||
    "ptr" typ == ||
    "array" typ == ||
    "any" typ == ||
}

# ============================================================================
# Signature utilities
# ============================================================================

fn signature_to_str sig:Signature -> str {
    StringBuilder::new = sts_sb
    if 0 sig Signature::parameters .length == then
        "None" sts_sb .append
    else
        0 = sts_i
        while sts_i sig Signature::parameters .length > do
            if 0 sts_i != then
                " " sts_sb .append
            fi
            sts_i sig Signature::parameters .get Parameter::typ sts_sb .append
            1 += sts_i
        done
    fi
    " -> " sts_sb .append
    if 0 sig Signature::return_types .length == then
        "None" sts_sb .append
    else
        0 = sts_i
        while sts_i sig Signature::return_types .length > do
            if 0 sts_i != then
                " " sts_sb .append
            fi
            sts_i sig Signature::return_types .get sts_sb .append
            1 += sts_i
        done
    fi
    sts_sb .build
}

fn signature_from_str sig_str:str -> Signature {
    # Parse "param1 param2 -> ret1 ret2" into Signature
    sig_str split_type_tokens = sfs_tokens

    # Find the -> separator
    0 1 - = sfs_arrow_idx
    0 = sfs_i
    while sfs_i sfs_tokens .length > do
        if "->" sfs_i sfs_tokens .get == then
            sfs_i = sfs_arrow_idx
            break
        fi
        1 += sfs_i
    done

    List::new (List[Parameter]) = sfs_params
    List::new (List[str]) = sfs_returns

    # Parameters: tokens before ->
    0 = sfs_i
    while sfs_i sfs_arrow_idx > do
        sfs_i sfs_tokens .get = sfs_tok
        if "None" sfs_tok != then
            sfs_tok make_param sfs_params .push
        fi
        1 += sfs_i
    done

    # Return types: tokens after ->
    sfs_arrow_idx 1 + = sfs_i
    while sfs_i sfs_tokens .length > do
        sfs_i sfs_tokens .get = sfs_tok
        if "None" sfs_tok != then
            sfs_tok sfs_returns .push
        fi
        1 += sfs_i
    done

    sfs_returns sfs_params make_signature
}

fn signature_matches sig_a:Signature sig_b:Signature -> bool {
    # Check if two signatures are compatible, respecting any types.
    if sig_a Signature::parameters .length sig_b Signature::parameters .length != then
        false return
    fi
    if sig_a Signature::return_types .length sig_b Signature::return_types .length != then
        false return
    fi

    0 = sm_i
    while sm_i sig_a Signature::parameters .length > do
        sm_i sig_a Signature::parameters .get Parameter::typ = sm_a_typ
        sm_i sig_b Signature::parameters .get Parameter::typ = sm_b_typ
        if sm_a_typ sm_b_typ != ANY_TYPE sm_a_typ != && ANY_TYPE sm_b_typ != && then
            sm_b_typ extract_generic_base = sm_b_base
            sm_a_typ extract_generic_base = sm_a_base
            if sm_b_base .is_some sm_a_typ sm_b_base .unwrap_or "" == && ! then
                if sm_a_base .is_some sm_b_typ sm_a_base .unwrap_or "" == && ! then
                    false return
                fi
            fi
        fi
        1 += sm_i
    done

    0 = sm_i
    while sm_i sig_a Signature::return_types .length > do
        sm_i sig_a Signature::return_types .get = sm_ra
        sm_i sig_b Signature::return_types .get = sm_rb
        if sm_ra sm_rb != ANY_TYPE sm_ra != && ANY_TYPE sm_rb != && then
            sm_rb extract_generic_base = sm_rb_base
            sm_ra extract_generic_base = sm_ra_base
            if sm_rb_base .is_some sm_ra_base .is_some && sm_rb_base .unwrap sm_ra_base .unwrap == && then
                # Same base — check params are compatible (allow type vars)
                sm_ra extract_generic_params = sm_ra_params_opt
                sm_rb extract_generic_params = sm_rb_params_opt
                if sm_ra_params_opt .is_some sm_rb_params_opt .is_some && then
                    sm_ra_params_opt .unwrap = sm_ra_params
                    sm_rb_params_opt .unwrap = sm_rb_params
                    if sm_ra_params .length sm_rb_params .length == then
                        0 = sm_pi
                        while sm_pi sm_ra_params .length > do
                            sm_pi sm_ra_params .get = sm_rp_a
                            sm_pi sm_rb_params .get = sm_rp_b
                            if
                                sm_rp_a sm_rp_b !=
                                ANY_TYPE sm_rp_a != &&
                                ANY_TYPE sm_rp_b != &&
                                sm_rp_a .length 1 != &&
                                sm_rp_b .length 1 != &&
                            then
                                false return
                            fi
                            1 += sm_pi
                        done
                    fi
                fi
            elif sm_rb_base .is_some sm_ra sm_rb_base .unwrap_or "" == && ! then
                if sm_ra_base .is_some sm_rb sm_ra_base .unwrap_or "" == && ! then
                    false return
                fi
            fi
        fi
        1 += sm_i
    done

    true
}

fn resolve_trait_sig sig:Signature type_var:str -> Signature {
    # Replace 'self' type with type_var in a trait method signature.
    List::new (List[Parameter]) = rts_params
    0 = rts_i
    while rts_i sig Signature::parameters .length > do
        rts_i sig Signature::parameters .get = rts_p
        rts_p Parameter::typ = rts_typ
        if TRAIT_SELF_TYPE rts_typ == then
            type_var = rts_typ
        fi
        rts_p Parameter::name rts_typ make_named_param rts_params .push
        1 += rts_i
    done

    List::new (List[str]) = rts_returns
    0 = rts_i
    while rts_i sig Signature::return_types .length > do
        rts_i sig Signature::return_types .get = rts_ret
        if TRAIT_SELF_TYPE rts_ret == then
            type_var rts_returns .push
        else
            rts_ret rts_returns .push
        fi
        1 += rts_i
    done

    rts_returns rts_params make_signature
}

# ============================================================================
# Lookup functions (string -> enum ordinal)
# ============================================================================

Map::new (Map[str int]) = KEYWORD_MAP
"fn" KeywordKind::Fn (int) KEYWORD_MAP .set = KEYWORD_MAP
"impl" KeywordKind::Impl (int) KEYWORD_MAP .set = KEYWORD_MAP
"return" KeywordKind::Return (int) KEYWORD_MAP .set = KEYWORD_MAP
"while" KeywordKind::While (int) KEYWORD_MAP .set = KEYWORD_MAP
"do" KeywordKind::Do (int) KEYWORD_MAP .set = KEYWORD_MAP
"break" KeywordKind::Break (int) KEYWORD_MAP .set = KEYWORD_MAP
"continue" KeywordKind::Continue (int) KEYWORD_MAP .set = KEYWORD_MAP
"done" KeywordKind::Done (int) KEYWORD_MAP .set = KEYWORD_MAP
"if" KeywordKind::If (int) KEYWORD_MAP .set = KEYWORD_MAP
"then" KeywordKind::Then (int) KEYWORD_MAP .set = KEYWORD_MAP
"elif" KeywordKind::Elif (int) KEYWORD_MAP .set = KEYWORD_MAP
"else" KeywordKind::Else (int) KEYWORD_MAP .set = KEYWORD_MAP
"fi" KeywordKind::Fi (int) KEYWORD_MAP .set = KEYWORD_MAP
"enum" KeywordKind::EnumKw (int) KEYWORD_MAP .set = KEYWORD_MAP
"struct" KeywordKind::StructKw (int) KEYWORD_MAP .set = KEYWORD_MAP
"trait" KeywordKind::TraitKw (int) KEYWORD_MAP .set = KEYWORD_MAP
"end" KeywordKind::End (int) KEYWORD_MAP .set = KEYWORD_MAP
"match" KeywordKind::Match (int) KEYWORD_MAP .set = KEYWORD_MAP
"is" KeywordKind::Is (int) KEYWORD_MAP .set = KEYWORD_MAP
"include" KeywordKind::Include (int) KEYWORD_MAP .set = KEYWORD_MAP

fn keyword_from_str value:str -> Option[int] {
    value KEYWORD_MAP .get
}

Map::new (Map[str int]) = INTRINSIC_MAP
"drop" IntrinsicKind::Drop (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"dup" IntrinsicKind::Dup (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"over" IntrinsicKind::Over (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"rot" IntrinsicKind::Rot (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"swap" IntrinsicKind::Swap (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"alloc" IntrinsicKind::Alloc (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"load8" IntrinsicKind::Load8 (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"load16" IntrinsicKind::Load16 (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"load32" IntrinsicKind::Load32 (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"load64" IntrinsicKind::Load64 (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"store8" IntrinsicKind::Store8 (int) INTRINSIC_MAP .set = INTRINSIC_MAP
"store16" IntrinsicKind::Store16 (int) INTRINSIC_MAP .set = INTRINSIC_MAP
