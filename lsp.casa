    OpKind::OpLoad16 TOKEN_MACRO TOKEN_TYPE_MAP.set = TOKEN_TYPE_MAP
    OpKind::OpLoad32 TOKEN_MACRO TOKEN_TYPE_MAP.set = TOKEN_TYPE_MAP
