    OpKind::OpStore16 TOKEN_MACRO TOKEN_TYPE_MAP.set = TOKEN_TYPE_MAP
    OpKind::OpStore32 TOKEN_MACRO TOKEN_TYPE_MAP.set = TOKEN_TYPE_MAP
    OpKind::OpStore64 TOKEN_MACRO TOKEN_TYPE_MAP.set = TOKEN_TYPE_MAP
