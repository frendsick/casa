import "std"

0 = test_pass_count
0 = test_fail_count
"" = test_current_name

fn test_start name:str {
    name = test_current_name
}

fn assert_eq actual:int expected:int message:str {
    if expected actual == then
        1 += test_pass_count
    else
        f"[FAIL] {test_current_name}: {message} (expected {expected}, got {actual})\n" eprint
        1 += test_fail_count
    fi
}

fn test_summary {
    f"{test_pass_count} passed, {test_fail_count} failed\n" print
    if 0 test_fail_count > then
        1 exit
    fi
}

# Regression test for the isolation bug (#171):
# A function that uses `= X` without `global X` must NOT modify a global X.
# Each `= X` creates a fresh local, no matter what globals exist.
42 = SHARED_VALUE

fn read_shared_value -> int {
    SHARED_VALUE
}

fn shadow_shared_value {
    # Without `global SHARED_VALUE`, this creates a local, not modifying the global.
    99 = SHARED_VALUE
    "local value" 99 SHARED_VALUE assert_eq
}

fn test_read_global_without_declaration {
    "read_global_without_declaration" test_start
    "reads global correctly" 42 read_shared_value assert_eq
}

fn test_silent_shadow {
    "silent_shadow" test_start
    shadow_shared_value
    "global unchanged" 42 SHARED_VALUE assert_eq
}
test_read_global_without_declaration
test_silent_shadow
test_summary
