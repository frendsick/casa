    empty_location 3 OpValue::PushInt Op::new ops_shl.push
    empty_location OpValue::Shl Op::new ops_shl.push
    ops_shl tc_check = tc_shl
    "shl result" "int" 0 tc_shl.stack.types.get.format assert_str_eq

    # BIT_AND
