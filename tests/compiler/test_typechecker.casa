# ============================================================================
# Tests: stack_effect_type_matches
# ============================================================================

fn test_types_match {
    "stack_effect_type_matches" test_start
    "same types" "int" parse_type_str "int" parse_type_str stack_effect_type_matches assert_true
    "TYPE_UNKNOWN matches int" "int" parse_type_str TYPE_UNKNOWN_T stack_effect_type_matches assert_true
    "int matches TYPE_UNKNOWN" TYPE_UNKNOWN_T "int" parse_type_str stack_effect_type_matches assert_true
    "different types" "str" parse_type_str "int" parse_type_str stack_effect_type_matches ! assert_true
    "fn base matches fn type" "fn[int -> int]" parse_type_str "fn" parse_type_str stack_effect_type_matches assert_true
    "bare generic rejects parameterized" "List[int]" parse_type_str "List" parse_type_str stack_effect_type_matches ! assert_true
}

# ============================================================================
# Tests: unify_type_t
# ============================================================================

fn test_unify_type {
    "unify_type_t" test_start
    symbol_store_new = store
    "same" "int" store "int" parse_type_str "int" parse_type_str unify_type_t.unwrap.format assert_str_eq
    "unknown + int" "int" store "int" parse_type_str TYPE_UNKNOWN_T unify_type_t.unwrap.format assert_str_eq
    "int + unknown" "int" store TYPE_UNKNOWN_T "int" parse_type_str unify_type_t.unwrap.format assert_str_eq
    "incompatible" store "str" parse_type_str "int" parse_type_str unify_type_t.is_none assert_true
}

# ============================================================================
# Tests: stacks_compatible
# ============================================================================

fn test_stacks_compatible {
    "stacks_compatible" test_start
    symbol_store_new = store
    List::new(List[Type]) = stack_a
    "int" parse_type_str stack_a.push
    "str" parse_type_str stack_a.push
    List::new(List[Type]) = stack_b
    "int" parse_type_str stack_b.push
    "str" parse_type_str stack_b.push
    store stack_b stack_a stacks_compatible = result
    "compatible stacks" 2 result.length assert_eq

    List::new(List[Type]) = stack_c
    "int" parse_type_str stack_c.push
    List::new(List[Type]) = stack_d
    "int" parse_type_str stack_d.push
    "str" parse_type_str stack_d.push
    store stack_d stack_c stacks_compatible = result2
    "incompatible lengths" 0 result2.length assert_eq
}

# ============================================================================
# Tests: Full type_check_ops via parsing
# ============================================================================

fn test_typecheck_simple_expression {
    "typecheck_simple_expression" test_start
    "10 20 +" parse_resolve_test_source = result
    result ParseResolveResult::ops = ops
    result ParseResolveResult::store = store
    store Option::None(Option[Function]) ops type_check_ops = sig
    "params" 0 sig StackEffect::parameters.length assert_eq
    "returns" 1 sig StackEffect::return_types.length assert_eq
    "return type" "int" 0 sig StackEffect::return_types.get.format assert_str_eq
}

# ============================================================================
# Helper: full pipeline typecheck
# ============================================================================

fn tc_string code:str -> StackEffect {
    code parse_resolve_test_source = result
    result ParseResolveResult::ops = ops
    result ParseResolveResult::store = store
    store Option::None(Option[Function]) ops type_check_ops
}

# ============================================================================
# Tests via full pipeline (lex -> parse -> resolve -> typecheck)
# Each tc_string call uses significant heap, so we batch assertions.
# ============================================================================

fn test_tc_pipeline_literals {
    "tc_pipeline_literals" test_start
    "42" tc_string = effect1
    "int count" 1 effect1 StackEffect::return_types.length assert_eq
    "int type" "int" 0 effect1 StackEffect::return_types.get.format assert_str_eq
    "true" tc_string = effect2
    "bool" "bool" 0 effect2 StackEffect::return_types.get.format assert_str_eq
    "\"hello\"" tc_string = effect3
    "str" "str" 0 effect3 StackEffect::return_types.get.format assert_str_eq
    "'a'" tc_string = effect4
    "char" "char" 0 effect4 StackEffect::return_types.get.format assert_str_eq
}

fn test_tc_pipeline_arithmetic {
    "tc_pipeline_arithmetic" test_start
    "1 2 +" tc_string = sa
    "add" "int" 0 sa StackEffect::return_types.get.format assert_str_eq
    "1 2 -" tc_string = ss
    "sub" "int" 0 ss StackEffect::return_types.get.format assert_str_eq
    "1 2 *" tc_string = sm
    "mul" "int" 0 sm StackEffect::return_types.get.format assert_str_eq
}

fn test_tc_pipeline_comparison {
    "tc_pipeline_comparison" test_start
    "1 2 ==" tc_string = sc
    "eq" "bool" 0 sc StackEffect::return_types.get.format assert_str_eq
    "1 2 <" tc_string = sl
    "lt" "bool" 0 sl StackEffect::return_types.get.format assert_str_eq
    "1 2 >=" tc_string = sg
    "ge" "bool" 0 sg StackEffect::return_types.get.format assert_str_eq
}

fn test_tc_pipeline_syscalls {
    "tc_pipeline_syscalls" test_start
    "60 syscall0" tc_string = s0
    "syscall0" "int" 0 s0 StackEffect::return_types.get.format assert_str_eq
    "0 60 syscall1" tc_string = s1
    "syscall1" "int" 0 s1 StackEffect::return_types.get.format assert_str_eq
    "0 0 0 0 60 syscall4" tc_string = s4
    "syscall4" "int" 0 s4 StackEffect::return_types.get.format assert_str_eq
}

fn test_tc_pipeline_stack_ops {
    "tc_pipeline_stack_ops" test_start
    "42 dup" tc_string = sd
    "dup count" 2 sd StackEffect::return_types.length assert_eq
    "42 drop" tc_string = sdr
    "drop count" 0 sdr StackEffect::return_types.length assert_eq
    "42 \"hi\" swap" tc_string = sw
    "swap count" 2 sw StackEffect::return_types.length assert_eq
    "swap first" "str" 0 sw StackEffect::return_types.get.format assert_str_eq
}

fn test_tc_pipeline_memory {
    "tc_pipeline_memory" test_start
    "10 alloc" tc_string = sa
    "alloc" "ptr" 0 sa StackEffect::return_types.get.format assert_str_eq
    "10 alloc load64" tc_string = sl
    "load64" "int" 0 sl StackEffect::return_types.get.format assert_str_eq
    "42 10 alloc store64" tc_string = ss
    "store64" 0 ss StackEffect::return_types.length assert_eq
}

