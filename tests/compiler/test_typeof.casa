import "../../compiler/common.casa"
import "../../compiler/error.casa"
import "../../compiler/lexer.casa"
import "../../compiler/syntax.casa"
import "../../compiler/typechecker.casa"
import "../../compiler/bytecode.casa"
import "../../compiler/emitter.casa"
import "../../lib/test.casa"

# ============================================================================
# Helpers
# ============================================================================

fn tc_typeof code:str -> Signature {
    "test" code lex_source = tokens
    tokens DEFAULT_PARSER parse_ops = ops
    ops DEFAULT_PARSER resolve_identifiers_global = ops
    Option::None(Option[Function]) ops type_check_ops
}

fn compile_typeof code:str -> Program {
    "test" code lex_source = tokens
    tokens DEFAULT_PARSER parse_ops = ops
    ops DEFAULT_PARSER resolve_identifiers_global = ops
    Option::None(Option[Function]) ops type_check_ops drop
    ops DEFAULT_PARSER.store compile_bytecode
}

fn emit_typeof code:str -> str {
    code compile_typeof emit
}

fn assert_contains needle:str haystack:str msg:str {
    haystack needle str::find = pos
    if 0 pos < then
        msg false assert_true
    else
        msg true assert_true
    fi
}

fn has_inst_kind bytecode:List[Inst] kind:InstKind -> bool {
    false = found
    0 = index
    while index bytecode.length > do
        if kind index bytecode.get Inst::kind == then
            true = found
        fi
        1 += index
    done
    found
}

fn string_table_contains table:List[str] needle:str -> bool {
    false = found
    0 = index
    while index table.length > do
        if needle index table.get == then
            true = found
        fi
        1 += index
    done
    found
}

# ============================================================================
# Lexer tests
# ============================================================================

fn test_lex_typeof {
    "lex_typeof" test_start
    "test" "typeof" lex_source = tokens
    "typeof kind" TokenKind::Intrinsic 0 tokens.get Token::kind == assert_true
    "typeof value" "typeof" 0 tokens.get Token::value assert_str_eq
}

# ============================================================================
# Parser tests
# ============================================================================

fn test_parse_typeof {
    "parse_typeof" test_start
    "test" "42 typeof" lex_source = tokens
    tokens DEFAULT_PARSER parse_ops = ops
    "typeof kind" 1 ops.get.value OpValue::Typeof is assert_true
}

# ============================================================================
# Typechecker tests
# ============================================================================

fn test_typecheck_typeof_returns_str_for_int {
    "typecheck_typeof_returns_str_for_int" test_start
    "42 typeof" tc_typeof = sig
    "one return" 1 sig Signature::return_types.length assert_eq
    "returns str" "str" 0 sig Signature::return_types.get assert_str_eq
}

fn test_typecheck_typeof_returns_str_for_bool {
    "typecheck_typeof_returns_str_for_bool" test_start
    "true typeof" tc_typeof = sig
    "returns str" "str" 0 sig Signature::return_types.get assert_str_eq
}

fn test_typecheck_typeof_returns_str_for_str {
    "typecheck_typeof_returns_str_for_str" test_start
    "\"hello\" typeof" tc_typeof = sig
    "returns str" "str" 0 sig Signature::return_types.get assert_str_eq
}

fn test_typecheck_typeof_returns_str_for_char {
    "typecheck_typeof_returns_str_for_char" test_start
    "'a' typeof" tc_typeof = sig
    "returns str" "str" 0 sig Signature::return_types.get assert_str_eq
}

fn test_typecheck_typeof_no_params {
    "typecheck_typeof_no_params" test_start
    "42 typeof" tc_typeof = sig
    "no params" 0 sig Signature::parameters.length assert_eq
}

fn test_typecheck_typeof_chained {
    "typecheck_typeof_chained" test_start
    "42 typeof drop true typeof" tc_typeof = sig
    "one return" 1 sig Signature::return_types.length assert_eq
    "returns str" "str" 0 sig Signature::return_types.get assert_str_eq
}

fn test_typecheck_typeof_ptr {
    "typecheck_typeof_ptr" test_start
    "10 alloc typeof" tc_typeof = sig
    "returns str" "str" 0 sig Signature::return_types.get assert_str_eq
}

# ============================================================================
# Bytecode tests
# ============================================================================

fn test_bytecode_typeof_int {
    "bytecode_typeof_int" test_start
    "42 typeof" compile_typeof = prog
    "has DROP" InstKind::InstDrop prog Program::bytecode has_inst_kind assert_true
    "has PUSH_STR" InstKind::InstPushStr prog Program::bytecode has_inst_kind assert_true
    "has PRINT_STR" InstKind::InstPrintStr prog Program::bytecode has_inst_kind assert_true
    "int in strings" "int" prog Program::strings string_table_contains assert_true
}

fn test_bytecode_typeof_bool {
    "bytecode_typeof_bool" test_start
    "true typeof" compile_typeof = prog
    "bool in strings" "bool" prog Program::strings string_table_contains assert_true
}

fn test_bytecode_typeof_str {
    "bytecode_typeof_str" test_start
    "\"hello\" typeof" compile_typeof = prog
    "str in strings" "str" prog Program::strings string_table_contains assert_true
}

fn test_bytecode_typeof_instruction_sequence {
    "bytecode_typeof_instruction_sequence" test_start
    "42 typeof" compile_typeof = prog
    # Find DROP -> PUSH_STR -> PRINT_STR sequence
    false = found_seq
    0 = index
    while index prog Program::bytecode.length 2 - > do
        index prog Program::bytecode.get Inst::kind = kind0
        index 1 + prog Program::bytecode.get Inst::kind = kind1
        index 2 + prog Program::bytecode.get Inst::kind = kind2
        if
        InstKind::InstDrop kind0 ==
        InstKind::InstPushStr kind1 == &&
        InstKind::InstPrintStr kind2 == &&
        then
            true = found_seq
        fi
        1 += index
    done
    "DROP -> PUSH_STR -> PRINT_STR sequence" found_seq assert_true
}

# ============================================================================
# Emitter tests
# ============================================================================

fn test_emit_typeof_int {
    "emit_typeof_int" test_start
    "42 typeof" emit_typeof = asm
    "has drop" asm "addq $8, %rsp" assert_contains
    "has print_str" asm "jmp print_str" assert_contains
}

fn test_emit_typeof_bool {
    "emit_typeof_bool" test_start
    "true typeof" emit_typeof = asm
    "has print_str" asm "jmp print_str" assert_contains
}

fn test_emit_typeof_str {
    "emit_typeof_str" test_start
    "\"hello\" typeof" emit_typeof = asm
    "has print_str" asm "jmp print_str" assert_contains
}

# ============================================================================
# Run all tests
# ============================================================================
test_lex_typeof
test_parse_typeof
test_typecheck_typeof_returns_str_for_int
test_typecheck_typeof_returns_str_for_bool
test_typecheck_typeof_returns_str_for_str
test_typecheck_typeof_returns_str_for_char
test_typecheck_typeof_no_params
test_typecheck_typeof_chained
test_typecheck_typeof_ptr
test_bytecode_typeof_int
test_bytecode_typeof_bool
test_bytecode_typeof_str
test_bytecode_typeof_instruction_sequence
test_emit_typeof_int
test_emit_typeof_bool
test_emit_typeof_str
test_summary
