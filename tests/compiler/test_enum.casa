    "42 match\n    1 => \"one\"\n    1 => \"one again\"\n    _ => \"other\"\nend\ndrop\n" tc_enum drop
    "has errors" assert_has_errors
    "duplicate name" ErrorKind::DuplicateName assert_error_kind
    clear_errors
    disable_test_mode
}

