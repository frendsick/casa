import "../../compiler/common.casa"
import "../../compiler/error.casa"
import "../../compiler/lexer.casa"
import "../../compiler/syntax.casa"
import "../../compiler/typechecker.casa"
import "../../lib/test.casa"

# ============================================================================
# Helpers
# ============================================================================

fn parse_snippet code:str {
    clear_global_state
    "test" code lex_source = tokens
    tokens DEFAULT_PARSER parse_ops drop
}

fn parse_and_resolve code:str {
    clear_global_state
    "test" code lex_source = tokens
    tokens DEFAULT_PARSER parse_ops = ops
    ops DEFAULT_PARSER resolve_identifiers_global drop
}

fn parse_resolve_typecheck code:str {
    clear_global_state
    "test" code lex_source = tokens
    tokens DEFAULT_PARSER parse_ops = ops
    ops DEFAULT_PARSER resolve_identifiers_global = ops
    Option::None(Option[Function]) ops type_check_ops drop
}

# ============================================================================
# Parse: `global X` in a function body produces no errors
# ============================================================================

fn test_global_decl_parses {
    "global_decl_parses" test_start
    enable_test_mode
    clear_errors
    "0 = LOG_LEVEL\nfn set_level level:int {\n    global LOG_LEVEL\n    level = LOG_LEVEL\n}\n" parse_snippet
    "no parse errors" assert_no_errors
    disable_test_mode
}

# ============================================================================
# Resolve: `global X` in a function resolves without errors
# ============================================================================

fn test_global_decl_resolves {
    "global_decl_resolves" test_start
    enable_test_mode
    clear_errors
    "0 = LOG_LEVEL\nfn set_level level:int {\n    global LOG_LEVEL\n    level = LOG_LEVEL\n}\n" parse_and_resolve
    "no resolve errors" assert_no_errors
    disable_test_mode
}

# ============================================================================
# Error: `global` at top level is INVALID_SCOPE
# ============================================================================

fn test_global_at_top_level_errors {
    "global_at_top_level_errors" test_start
    enable_test_mode
    clear_errors
    "0 = X\nglobal X\n" parse_snippet
    "has INVALID_SCOPE error" ErrorKind::InvalidScope assert_error_kind
    clear_errors
    disable_test_mode
}

# ============================================================================
# Error: `global` in a lambda is an error
# ============================================================================

fn test_global_in_lambda_errors {
    "global_in_lambda_errors" test_start
    enable_test_mode
    clear_errors
    "0 = X\nfn foo {\n    { global X\n    1 = X } exec\n}\n" parse_snippet
    "has error for global in lambda" assert_has_errors
    clear_errors
    disable_test_mode
}

# ============================================================================
# Error: `global X` after body statements is an error
# ============================================================================

fn test_global_after_body_errors {
    "global_after_body_errors" test_start
    enable_test_mode
    clear_errors
    "0 = X\nfn foo {\n    0 = local_var\n    global X\n}\n" parse_snippet
    "has error for global after body" assert_has_errors
    clear_errors
    disable_test_mode
}

# ============================================================================
# Error: `global NONEXISTENT` produces an error (nonexistent global)
# ============================================================================

fn test_global_nonexistent_errors {
    "global_nonexistent_errors" test_start
    enable_test_mode
    clear_errors
    "fn foo {\n    global NONEXISTENT\n    0 = NONEXISTENT\n}\nfoo\n" parse_resolve_typecheck
    "has error for nonexistent global" assert_has_errors
    clear_errors
    disable_test_mode
}

# ============================================================================
# Isolation: lib fn with `= value` compiles cleanly when user has global value
# ============================================================================

fn test_isolation_no_type_error {
    "isolation_no_type_error" test_start
    enable_test_mode
    clear_errors
    "\"hello\" = value\nfn process_value {\n    42 = value\n    value 1 + drop\n}\nprocess_value\n" parse_resolve_typecheck
    "no type mismatch after fix" assert_no_errors
    disable_test_mode
}

# ============================================================================
# Run all tests
# ============================================================================
test_global_decl_parses
test_global_decl_resolves
test_global_at_top_level_errors
test_global_in_lambda_errors
test_global_after_body_errors
test_global_nonexistent_errors
test_isolation_no_type_error
test_summary
