    List::new(List[Inst]) = fn_bytecode
    Map::new(Map[str List[Inst]]) = functions
    "Foo::bar" fn_bytecode functions.set = functions

    0 0 List::new(List[str]) functions bytecode Program = program
    program emit = result
    "has jmp fn_Foo__bar" result "jmp fn_Foo__bar" assert_contains
    "has fn_Foo__bar label" result "fn_Foo__bar:" assert_contains
}

fn test_emit_start_section {
    "emit_start_section" test_start
    make_empty_program emit = result
    "has _start label" result "_start:" assert_contains
    "has globl" result ".globl _start" assert_contains
    "has return_stack init" result "leaq return_stack(%rip), %r14" assert_contains
    "has exit syscall" result "movq $60, %rax" assert_contains
}

