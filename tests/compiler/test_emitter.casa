# ---------------------------------------------------------------------------
# Globals init (no-op, BSS handles allocation)
# ---------------------------------------------------------------------------

fn test_emit_globals_init {
    "emit_globals_init" test_start
    List::new(List[Inst]) = bytecode
    5 InstKind::InstGlobalsInit make_inst_int bytecode.push
    42 InstKind::InstPush make_inst_int bytecode.push

    0 5 List::new(List[str])
    Map::new(Map[str List[Inst]])
    bytecode
    Program = program

    program emit = result
    # GlobInit itself is no-op but the push after it should be there
    "has pushq $42" result "pushq $42" assert_contains
    # BSS should reserve space for 5 globals
    "has globals skip" result "globals: .skip 40" assert_contains
}

# ---------------------------------------------------------------------------
# While loop pattern (label + jump_ne + unconditional jump)
# ---------------------------------------------------------------------------

fn test_emit_while_loop_pattern {
    "emit_while_loop_pattern" test_start
    List::new(List[Inst]) = bytecode
    # while loop: label 10, condition check, jump_ne 11, body, jump 10, label 11
    10 InstKind::InstLabel make_inst_int bytecode.push
    1 InstKind::InstPush make_inst_int bytecode.push
    11 InstKind::InstJumpNe make_inst_int bytecode.push
    10 InstKind::InstJump make_inst_int bytecode.push
    11 InstKind::InstLabel make_inst_int bytecode.push

    0 0 List::new(List[str])
    Map::new(Map[str List[Inst]])
    bytecode
    Program = program

    program emit = result
    "has loop start label" result ".L10:" assert_contains
    "has conditional jz" result "jz .L11" assert_contains
    "has unconditional jmp" result "jmp .L10" assert_contains
    "has loop end label" result ".L11:" assert_contains
}

# ---------------------------------------------------------------------------
# Data section with escape sequences
# ---------------------------------------------------------------------------

fn test_emit_data_escape_sequences {
    "emit_data_escape_sequences" test_start
    List::new(List[str]) = strings
    "hello\nworld" strings.push
    "col1\tcol2" strings.push

    0 0 strings
    Map::new(Map[str List[Inst]])
    List::new(List[Inst])
    Program = program

    StringBuilder::new = asm_builder
    program asm_builder emit_data
    asm_builder.build = result

    "has escaped newline" result "hello\\nworld" assert_contains
    "has escaped tab" result "col1\\tcol2" assert_contains
}

