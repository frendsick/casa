import "../../lib/test.casa"

# Helper: check that a string contains a substring

fn assert_contains needle:str haystack:str msg:str {
    haystack needle str::find = position
    if 0 position < then
        msg false assert_true
    else
        msg true assert_true
    fi
}
# Helper: build a minimal program with no bytecode

fn make_empty_program -> Program {
    0 0
    List::new(List[str])
    Map::new(Map[str List[Inst]])
    List::new(List[Inst])
    Program
}
# Helper: build a program with given bytecode and strings

fn make_simple_program bytecode:List[Inst] strings:List[str] globals:int constants:int -> Program {
    constants globals strings
    Map::new(Map[str List[Inst]])
    bytecode
    Program
}

fn test_sanitize_name {
    "sanitize_name" test_start
    "simple name" "foo" "foo" sanitize_name assert_str_eq
    "double colon" "Foo__bar" "Foo::bar" sanitize_name assert_str_eq
    "multiple" "A__B__C" "A::B::C" sanitize_name assert_str_eq
    "no colons" "hello_world" "hello_world" sanitize_name assert_str_eq
    "single colon preserved" "a:b" "a:b" sanitize_name assert_str_eq
}

fn test_escape_string {
    "escape_string" test_start
    "plain" "hello" "hello" escape_string assert_str_eq
    "newline" "a\\nb" "a\nb" escape_string assert_str_eq
    "tab" "a\\tb" "a\tb" escape_string assert_str_eq
    "backslash" "\\\\" "\\" escape_string assert_str_eq
    "quote" "\\\"" "\"" escape_string assert_str_eq
}

fn test_emit_bss {
    "emit_bss" test_start
    3 = globals
    2 = constants
    constants globals
    List::new(List[str])
    Map::new(Map[str List[Inst]])
    List::new(List[Inst])
    Program = program

    StringBuilder::new = asm_builder
    program asm_builder emit_bss
    asm_builder.build = result

    "has bss section" result ".section .bss" assert_contains
    "has globals" result "globals: .skip 24" assert_contains
    "has constants" result "constants: .skip 16" assert_contains
    "has return stack" result "return_stack: .skip 65536" assert_contains
    "has heap" result "heap: .skip 1073741824" assert_contains
    "has heap_ptr" result "heap_ptr: .skip 8" assert_contains
    "has argc" result "__argc: .skip 8" assert_contains
    "has argv" result "__argv: .skip 8" assert_contains
    "has print_buf" result "print_buf: .skip 32" assert_contains
}

fn test_emit_data {
    "emit_data" test_start
    List::new(List[str]) = strings
    "hello" strings.push
    "world" strings.push

    0 0 strings
    Map::new(Map[str List[Inst]])
    List::new(List[Inst])
    Program = program

    StringBuilder::new = asm_builder
    program asm_builder emit_data
    asm_builder.build = result

    "has data section" result ".section .data" assert_contains
    "has str_0 label" result "str_0:" assert_contains
    "has str_1 label" result "str_1:" assert_contains
    "has quad 5 for hello" result ".quad 5" assert_contains
    "has hello ascii" result ".asciz \"hello\"" assert_contains
    "has quad 5 for world" result ".quad 5" assert_contains
    "has bool_true" result "bool_true:" assert_contains
    "has bool_false" result "bool_false:" assert_contains
}

fn test_emit_push {
    "emit_push" test_start
    List::new(List[Inst]) = bytecode
    42 InstKind::InstPush make_inst_int bytecode.push

    0 0 List::new(List[str])
    Map::new(Map[str List[Inst]])
    bytecode
    Program = program

    program emit = result
    "has pushq $42" result "pushq $42" assert_contains
}

