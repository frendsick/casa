fn test_emit_syscall2 {
    "emit_syscall2" test_start
    List::new(List[Inst]) = bytecode
    InstKind::InstSyscall2 make_inst bytecode.push

    0 0 List::new(List[str])
    Map::new(Map[str List[Inst]])
    bytecode
    Program = program

    program emit = result
    "has popq rax" result "popq %rax" assert_contains
    "has popq rdi" result "popq %rdi" assert_contains
    "has popq rsi" result "popq %rsi" assert_contains
    "has syscall" result "    syscall" assert_contains
    "has pushq rax" result "pushq %rax" assert_contains
}

