import "../../lsp.casa"
import "../../lib/test.casa"

# Synthetic file path used for tests that don't need a real file on disk.
"/tmp/lsp_test.casa" = LSP_TEST_FILE

fn lsp_clear_documents {
    Map::new(Map[str DocumentState]) = DOCUMENT_STATES
}

fn lsp_test_state source:str -> DocumentState {
    lsp_clear_documents
    DOCUMENT_STATES source LSP_TEST_FILE compile_document CompileResult::document_state
}

fn lsp_test_uri -> str {
    LSP_TEST_FILE path_to_uri
}

# ============================================================================
# Test: offset_to_lsp_range
# ============================================================================

fn test_offset_to_lsp_range_single_line_start {
    "offset_to_lsp_range_single_line_start" test_start
    5 0 "hello world" offset_to_lsp_range = range
    "start_line" 0 range LspRange::start_line assert_eq
    "start_col" 0 range LspRange::start_col assert_eq
    "end_line" 0 range LspRange::end_line assert_eq
    "end_col" 5 range LspRange::end_col assert_eq
}

fn test_offset_to_lsp_range_multiline_second_line {
    "offset_to_lsp_range_multiline_second_line" test_start
    6 6 "first\nsecond" offset_to_lsp_range = range
    "start_line" 1 range LspRange::start_line assert_eq
    "start_col" 0 range LspRange::start_col assert_eq
    "end_line" 1 range LspRange::end_line assert_eq
    "end_col" 6 range LspRange::end_col assert_eq
}

fn test_offset_to_lsp_range_zero_length_uses_minimum_of_one {
    "offset_to_lsp_range_zero_length_uses_minimum_of_one" test_start
    0 1 "abc" offset_to_lsp_range = range
    "start_line" 0 range LspRange::start_line assert_eq
    "start_col" 1 range LspRange::start_col assert_eq
    "end_line" 0 range LspRange::end_line assert_eq
    "end_col" 2 range LspRange::end_col assert_eq
}

fn test_offset_to_lsp_range_mid_line_offset {
    "offset_to_lsp_range_mid_line_offset" test_start
    5 6 "hello world" offset_to_lsp_range = range
    "start_line" 0 range LspRange::start_line assert_eq
    "start_col" 6 range LspRange::start_col assert_eq
    "end_line" 0 range LspRange::end_line assert_eq
    "end_col" 11 range LspRange::end_col assert_eq
}

