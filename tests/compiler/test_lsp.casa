# ============================================================================
# Helper: build a synthetic Function with a single self:T parameter
# ============================================================================

fn lsp_make_synthetic_method name:str self_type:str ret_type:str -> Function {
    List::new(List[Parameter]) = params
    self_type make_param params.push
    List::new(List[str]) = returns
    ret_type returns.push
    returns params make_signature = sig
    sig empty_location List::new(List[Op]) name make_function_with_sig
}

fn lsp_make_synthetic_void name:str self_type:str -> Function {
    List::new(List[Parameter]) = params
    self_type make_param params.push
    List::new(List[str]) = returns
    returns params make_signature = sig
    sig empty_location List::new(List[Op]) name make_function_with_sig
}
# Inject int:: synthetic methods into a DocumentState's functions map.
# Returns a new DocumentState with the updated functions map.

fn lsp_inject_int_methods state:DocumentState -> DocumentState {
    state DocumentState::functions = fns
    "int::hash" "int" "int" "int::hash" lsp_make_synthetic_method fns.set = fns
    "int::eq" "int" "int" "int::eq" lsp_make_synthetic_method fns.set = fns
    state DocumentState::file_path
    state DocumentState::source
    state DocumentState::variables
    state DocumentState::enums
    state DocumentState::structs
    fns
    state DocumentState::ops
    DocumentState
}

