# ============================================================================
# Helper: search the items list for a label
# ============================================================================

fn lsp_completion_has items:List[CompletionItem] label:str -> bool {
    0 = index
    while index items.length > do
        if index items.get CompletionItem::label label == then
            true return
        fi
        1 += index
    done
    false
}

fn lsp_completion_first_kind items:List[CompletionItem] label:str -> int {
    0 = index
    while index items.length > do
        index items.get = item
        if item CompletionItem::label label == then
            item CompletionItem::kind return
        fi
        1 += index
    done
    0 1 -
}

