# ============================================================================
# Test: compute_hover
# ============================================================================

fn test_compute_hover_function {
    "compute_hover_function" test_start
    "fn add x:int y:int -> int {\n    x y +\n}\n1 2 add" lsp_test_state = state
    4 3 state compute_hover = result
    "is some" result.is_some assert_true
    result.unwrap HoverContent::content = content
    "contains fn add" 0 content "fn add" str::find >= assert_true
    "contains x:int" 0 content "x:int" str::find >= assert_true
    "contains y:int" 0 content "y:int" str::find >= assert_true
}

