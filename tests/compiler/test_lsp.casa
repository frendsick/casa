    0 = lambda_index
    while lambda_index items.length > do
        if lambda_index items.get CompletionItem::label "lambda__" str::starts_with then
            1 += lambda_count
        fi
        1 += lambda_index
    done
    "no lambda" 0 lambda_count assert_eq
}

