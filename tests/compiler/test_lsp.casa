# ============================================================================
# Test: find_variable_definition with reassignment
# ============================================================================

fn test_find_variable_definition_returns_last_assignment_before_usage {
    "find_variable_definition_returns_last_assignment_before_usage" test_start
    "1 = x\n2 = x\nx print" = source
    source lsp_test_state = state
    source "x print" str::find = usage_offset
    usage_offset state Option::None(Option[Function]) "x" find_variable_definition = location
    "is some" location.is_some assert_true
    "line is 1" 1 location.unwrap LspLocation::range LspRange::start_line assert_eq
}

fn test_find_variable_definition_returns_first_assignment_when_usage_before_reassignment {
    "find_variable_definition_returns_first_assignment_when_usage_before_reassignment" test_start
    "1 = x\nx print\n2 = x" = source
    source lsp_test_state = state
    source "x print" str::find = usage_offset
    usage_offset state Option::None(Option[Function]) "x" find_variable_definition = location
    "is some" location.is_some assert_true
    "line is 0" 0 location.unwrap LspLocation::range LspRange::start_line assert_eq
}

fn test_find_variable_definition_falls_back_to_first_assignment_without_usage_offset {
    "find_variable_definition_falls_back_to_first_assignment_without_usage_offset" test_start
    "1 = x\n2 = x\nx print" lsp_test_state = state
    0 state Option::None(Option[Function]) "x" find_variable_definition = location
    "is some" location.is_some assert_true
    "line is 0" 0 location.unwrap LspLocation::range LspRange::start_line assert_eq
}

fn test_find_variable_definition_reassigned_local_variable_in_function {
    "find_variable_definition_reassigned_local_variable_in_function" test_start
    "fn foo {\n    1 = x\n    2 = x\n    x print\n}\nfoo" = source
    source lsp_test_state = state
    "foo" state DocumentState::functions.get = func
    source "x print" str::find = usage_offset
    usage_offset state func "x" find_variable_definition = location
    "is some" location.is_some assert_true
    "line is 2" 2 location.unwrap LspLocation::range LspRange::start_line assert_eq
}

