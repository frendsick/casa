# ============================================================================
# Test: compute_semantic_tokens
# ============================================================================

fn lsp_token_types tokens:List[SemanticToken] -> List[int] {
    List::new(List[int]) = types
    0 = index
    while index tokens.length > do
        index tokens.get SemanticToken::token_type types.push
        1 += index
    done
    types
}

fn lsp_int_list_contains list:List[int] target:int -> bool {
    0 = index
    while index list.length > do
        if index list.get target == then
            true return
        fi
        1 += index
    done
    false
}

fn lsp_int_list_count list:List[int] target:int -> int {
    0 = count
    0 = index
    while index list.length > do
        if index list.get target == then
            1 += count
        fi
        1 += index
    done
    count
}

