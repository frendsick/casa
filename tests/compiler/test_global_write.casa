import "std"

0 = test_pass_count
0 = test_fail_count
"" = test_current_name

fn test_start name:str {
    name = test_current_name
}

fn assert_eq actual:int expected:int message:str {
    if expected actual == then
        1 += test_pass_count
    else
        f"[FAIL] {test_current_name}: {message} (expected {expected}, got {actual})\n" eprint
        1 += test_fail_count
    fi
}

fn test_summary {
    f"{test_pass_count} passed, {test_fail_count} failed\n" print
    if 0 test_fail_count > then
        1 exit
    fi
}
0 = COUNTER

fn increment {
    global COUNTER
    1 += COUNTER
}

fn decrement {
    global COUNTER
    1 -= COUNTER
}

fn reset_counter {
    global COUNTER
    0 = COUNTER
}

fn set_counter val:int {
    global COUNTER
    val = COUNTER
}

fn test_global_increment {
    "global_increment" test_start
    reset_counter
    "initial" 0 COUNTER assert_eq
    increment
    "after first increment" 1 COUNTER assert_eq
    increment
    "after second increment" 2 COUNTER assert_eq
}

fn test_global_decrement {
    "global_decrement" test_start
    reset_counter
    increment
    increment
    increment
    "after three increments" 3 COUNTER assert_eq
    decrement
    "after decrement" 2 COUNTER assert_eq
}

fn test_global_assign {
    "global_assign" test_start
    reset_counter
    "before assign" 0 COUNTER assert_eq
    42 set_counter
    "after assign" 42 COUNTER assert_eq
}
test_global_increment
test_global_decrement
test_global_assign
test_summary
