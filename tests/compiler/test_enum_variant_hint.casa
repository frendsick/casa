include "../../compiler/common.casa"
include "../../compiler/error.casa"
include "../../compiler/lexer.casa"
include "../../compiler/parser.casa"
include "../../compiler/typechecker.casa"
include "../../lib/test.casa"

"enum Color { Red Green Blue }\n" = EVH_COLOR_ENUM
"enum Direction { North South East West }\n" = EVH_DIRECTION_ENUM

# ============================================================================
# Helpers
# ============================================================================

fn tc_evh code:str -> Signature {
    clear_global_state
    "test" code lex_source = tokens
    tokens DEFAULT_PARSER parse_ops = ops
    ops DEFAULT_PARSER resolve_identifiers_global = ops
    Option::None (Option[Function]) ops type_check_ops
}

# ============================================================================
# Bare variant hint tests
# ============================================================================

fn test_bare_variant_produces_type_mismatch {
    "bare_variant_produces_type_mismatch" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "enum Color { Red Green Blue }\nColor::Green match\n    Color::Red => 1\n    Green => 2\n    Color::Blue => 3\nend\n" tc_evh drop
    "has errors" assert_has_errors
    "type mismatch" ErrorKind::TypeMismatch assert_error_kind
    clear_errors
    disable_test_mode
}

fn test_bare_variant_hint_contains_qualified_name {
    "bare_variant_hint_contains_qualified_name" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "enum Color { Red Green Blue }\nColor::Green match\n    Color::Red => 1\n    Green => 2\n    Color::Blue => 3\nend\n" tc_evh drop
    "has Did you mean" "Did you mean `Color::Green`?" assert_error_contains
    clear_errors
    disable_test_mode
}

fn test_bare_variant_first_arm {
    "bare_variant_first_arm" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "enum Color { Red Green Blue }\nColor::Red match\n    Red => 1\n    Color::Green => 2\n    Color::Blue => 3\nend\n" tc_evh drop
    "has type mismatch" ErrorKind::TypeMismatch assert_error_kind
    "has hint" "Did you mean `Color::Red`?" assert_error_contains
    clear_errors
    disable_test_mode
}

fn test_bare_variant_last_arm {
    "bare_variant_last_arm" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "enum Color { Red Green Blue }\nColor::Red match\n    Color::Red => 1\n    Color::Green => 2\n    Blue => 3\nend\n" tc_evh drop
    "has type mismatch" ErrorKind::TypeMismatch assert_error_kind
    "has hint" "Did you mean `Color::Blue`?" assert_error_contains
    clear_errors
    disable_test_mode
}

fn test_bare_variant_not_in_any_enum_no_hint {
    "bare_variant_not_in_any_enum_no_hint" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "enum Color { Red Green Blue }\nColor::Red match\n    Color::Red => 1\n    Foo => 2\n    Color::Blue => 3\nend\n" tc_evh drop
    "has errors" assert_has_errors
    # Should NOT contain "Did you mean" since Foo is not a variant of Color
    false = has_hint
    0 = index
    while index ERRORS .length > do
        index ERRORS .get CasaError::message = message
        if 0 message "Did you mean" str::find >= then
            true = has_hint
        fi
        1 += index
    done
    "no hint for unknown name" has_hint ! assert_true
    clear_errors
    disable_test_mode
}

fn test_all_bare_variants_errors_on_first {
    "all_bare_variants_errors_on_first" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "enum Color { Red Green Blue }\nColor::Red match\n    Red => 1\n    Green => 2\n    Blue => 3\nend\n" tc_evh drop
    "has type mismatch" ErrorKind::TypeMismatch assert_error_kind
    "has hint for Red" "Did you mean `Color::Red`?" assert_error_contains
    clear_errors
    disable_test_mode
}

fn test_bare_variant_from_different_enum_no_hint {
    "bare_variant_from_different_enum_no_hint" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "enum Color { Red Green Blue }\nenum Direction { North South East West }\nColor::Red match\n    Color::Red => 1\n    North => 2\n    Color::Blue => 3\nend\n" tc_evh drop
    "has errors" assert_has_errors
    # Should NOT contain "Did you mean" since North is from Direction, not Color
    false = has_hint
    0 = index
    while index ERRORS .length > do
        index ERRORS .get CasaError::message = message
        if 0 message "Did you mean" str::find >= then
            true = has_hint
        fi
        1 += index
    done
    "no hint for different enum" has_hint ! assert_true
    clear_errors
    disable_test_mode
}

# ============================================================================
# Qualified variants still work
# ============================================================================

fn test_qualified_match_all_arms {
    "qualified_match_all_arms" test_start
    "enum Color { Red Green Blue }\nColor::Red match\n    Color::Red => 1\n    Color::Green => 2\n    Color::Blue => 3\nend\ndrop\n" tc_evh drop
    "passes" true assert_true
}

fn test_qualified_match_with_function {
    "qualified_match_with_function" test_start
    "enum Color { Red Green Blue }\nfn color_val c:Color -> int {\n    c match\n        Color::Red => 0\n        Color::Green => 1\n        Color::Blue => 2\n    end\n}\nColor::Green color_val\ndrop\n" tc_evh drop
    "passes" true assert_true
}

# ============================================================================
# Wildcard still works
# ============================================================================

fn test_wildcard_covers_remaining {
    "wildcard_covers_remaining" test_start
    "enum Color { Red Green Blue }\nColor::Red match\n    Color::Red => 1\n    _ => 0\nend\ndrop\n" tc_evh drop
    "passes" true assert_true
}

fn test_wildcard_with_one_explicit_arm {
    "wildcard_with_one_explicit_arm" test_start
    "enum Color { Red Green Blue }\nColor::Green match\n    Color::Red => 1\n    _ => 0\nend\ndrop\n" tc_evh drop
    "passes" true assert_true
}

# ============================================================================
# Run all tests
# ============================================================================

test_bare_variant_produces_type_mismatch
test_bare_variant_hint_contains_qualified_name
test_bare_variant_first_arm
test_bare_variant_last_arm
test_bare_variant_not_in_any_enum_no_hint
test_all_bare_variants_errors_on_first
test_bare_variant_from_different_enum_no_hint
test_qualified_match_all_arms
test_qualified_match_with_function
test_wildcard_covers_remaining
test_wildcard_with_one_explicit_arm
test_summary
