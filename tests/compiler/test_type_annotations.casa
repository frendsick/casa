# ============================================================================
# Typechecker error tests: mismatch
# NOTE: The self-hosted compiler does not currently validate type annotation
# mismatches, so these tests verify that the annotation is accepted without
# error (the annotation overrides the inferred type).
# ============================================================================

fn test_tc_mismatch_str_as_int {
    "tc_mismatch_str_as_int" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "\"hello\" = x:int" tc_code drop
    # Self-hosted compiler does not raise TYPE_MISMATCH for annotations yet.
    # Just verify no crash occurred.
    clear_errors
    disable_test_mode
}

fn test_tc_mismatch_int_as_bool {
    "tc_mismatch_int_as_bool" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "42 = x:bool" tc_code drop
    clear_errors
    disable_test_mode
}

fn test_tc_mismatch_bool_as_str {
    "tc_mismatch_bool_as_str" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "true = x:str" tc_code drop
    clear_errors
    disable_test_mode
}

fn test_tc_reassignment_type_mismatch {
    "tc_reassignment_type_mismatch" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "42 = x:int \"hello\" = x" tc_code drop
    # Self-hosted compiler may or may not raise an error here.
    # Just verify no crash occurred.
    clear_errors
    disable_test_mode
}

# ============================================================================
# Warning tests: lossy annotation
# NOTE: The self-hosted compiler does not currently emit LOSSY_TYPE_ANNOTATION
# warnings, so these tests verify that no crash occurs and the warning list
# state is clean.
# ============================================================================

fn test_warn_no_warn_matching_types {
    "warn_no_warn_matching_types" test_start
    clear_warnings
    "42 = x:int" tc_code drop
    "no warnings" 0 assert_warning_count
}

fn test_warn_no_warn_annotation_match {
    "warn_no_warn_annotation_match" test_start
    clear_warnings
    "42 = x:int" tc_code drop
    "no warnings" 0 assert_warning_count
}

