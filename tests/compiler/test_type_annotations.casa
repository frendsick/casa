import "../../compiler/typechecker.casa"
import "helpers.casa"

# ============================================================================
# Constants
# ============================================================================
"enum Option[T] { None Some(T) }\n" = OPTION_ENUM
symbol_store_new = TYPE_ANNOTATION_TEST_STORE

# ============================================================================
# Helpers
# ============================================================================

fn test_parse code:str -> List[Op] {
    global TYPE_ANNOTATION_TEST_STORE
    clear_global_state
    code parse_resolve_test_source = result
    result ParseResolveResult::store = TYPE_ANNOTATION_TEST_STORE
    result ParseResolveResult::ops
}

fn tc_code code:str -> StackEffect {
    global TYPE_ANNOTATION_TEST_STORE
    clear_global_state
    code parse_resolve_test_source = result
    result ParseResolveResult::ops = ops
    result ParseResolveResult::store = TYPE_ANNOTATION_TEST_STORE
    TYPE_ANNOTATION_TEST_STORE Option::None(Option[Function]) ops type_check_ops
}

fn find_assign_ops ops:List[Op] -> List[Op] {
    List::new(List[Op]) = result
    0 = index
    while index ops.length > do
        index ops.get = op
        if op.value OpValue::AssignVar is then
            op result.push
        fi
        1 += index
    done
    result
}

fn find_ops_by_kind ops:List[Op] kind:OpValue -> List[Op] {
    List::new(List[Op]) = result
    0 = index
    while index ops.length > do
        index ops.get = op
        if op.value kind == then
            op result.push
        fi
        1 += index
    done
    result
}

# ============================================================================
# Parser tests: annotation parsing
# ============================================================================

fn test_annotation_int {
    "annotation_int" test_start
    "42 = x:int" test_parse = ops
    ops find_assign_ops = assigns
    "count" 1 assigns.length assert_eq
    "name" "x" 0 assigns.get op_str_value assert_str_eq
    "annotation" "int" parse_type_str 0 assigns.get Op::type_hint.unwrap.eq assert_true
}

fn test_annotation_str {
    "annotation_str" test_start
    "\"hello\" = x:str" test_parse = ops
    ops find_assign_ops = assigns
    "annotation" "str" parse_type_str 0 assigns.get Op::type_hint.unwrap.eq assert_true
}

fn test_annotation_bool {
    "annotation_bool" test_start
    "true = x:bool" test_parse = ops
    ops find_assign_ops = assigns
    "annotation" "bool" parse_type_str 0 assigns.get Op::type_hint.unwrap.eq assert_true
}

