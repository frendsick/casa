include "../../compiler/common.casa"
include "../../compiler/error.casa"
include "../../compiler/lexer.casa"
include "../../compiler/parser.casa"
include "../../compiler/typechecker.casa"
include "../../compiler/bytecode.casa"
include "../../compiler/emitter.casa"
include "../../lib/test.casa"

# ============================================================================
# Array method tests
#
# These test that array operations compile through the self-hosted pipeline.
# Since the test pipeline uses lex_source (in-memory), we cannot include
# lib/std.casa inline. Instead, we test the underlying primitives that
# array methods use: array literals, method calls, lambdas, and fn types.
# ============================================================================

fn tc_am code:str -> Signature {
    clear_global_state
    "test" code lex_source = tokens
    tokens DEFAULT_PARSER parse_ops = ops
    ops DEFAULT_PARSER resolve_identifiers_global = ops
    Option::None (Option[Function]) ops type_check_ops
}

fn compile_am code:str -> Program {
    clear_global_state
    "test" code lex_source = tokens
    tokens DEFAULT_PARSER parse_ops = ops
    ops DEFAULT_PARSER resolve_identifiers_global = ops
    Option::None (Option[Function]) ops type_check_ops drop
    ops DEFAULT_PARSER.store compile_bytecode
}

fn emit_am code:str -> str {
    code compile_am emit
}

fn assert_contains needle:str haystack:str msg:str {
    haystack needle str::find = position
    if 0 position < then
        msg false assert_true
    else
        msg true assert_true
    fi
}

# ============================================================================
# Array literal tests
# ============================================================================

fn test_array_literal_type {
    "array_literal_type" test_start
    "[1, 2, 3]" tc_am = sig
    "returns array" 1 sig Signature::return_types .length assert_eq
}

fn test_array_literal_compiles {
    "array_literal_compiles" test_start
    "[1, 2, 3] drop" compile_am = prog
    "has bytecode" 0 prog Program::bytecode .length != assert_true
}

fn test_array_literal_emits {
    "array_literal_emits" test_start
    "[1, 2, 3] drop" emit_am = asm
    "has _start" asm "_start:" assert_contains
}

# ============================================================================
# Lambda tests (used by map/filter/reduce)
# ============================================================================

fn test_lambda_type {
    "lambda_type" test_start
    "{ 2 * }" tc_am = sig
    "returns fn" 1 sig Signature::return_types .length assert_eq
}

fn test_lambda_compiles {
    "lambda_compiles" test_start
    "{ 2 * } drop" compile_am = prog
    "has bytecode" 0 prog Program::bytecode .length != assert_true
}

fn test_lambda_emits {
    "lambda_emits" test_start
    "{ 2 * } drop" emit_am = asm
    "has _start" asm "_start:" assert_contains
}

# ============================================================================
# Function type tests
# ============================================================================

fn test_fn_push_type {
    "fn_push_type" test_start
    "fn double x:int -> int { x 2 * }\n{ 2 * }" tc_am = sig
    "has fn type" 1 sig Signature::return_types .length assert_eq
}

fn test_fn_call_compiles {
    "fn_call_compiles" test_start
    "fn double x:int -> int { x 2 * }\n42 double" tc_am = sig
    "returns int" "int" 0 sig Signature::return_types .get assert_str_eq
}

# ============================================================================
# Array with lambda pipeline
# ============================================================================

fn test_array_and_lambda_compiles {
    "array_and_lambda_compiles" test_start
    "[1, 2, 3] = arr { 2 * } = mapper arr drop mapper drop" compile_am = prog
    "has bytecode" 0 prog Program::bytecode .length != assert_true
}

fn test_array_and_lambda_emits {
    "array_and_lambda_emits" test_start
    "[1, 2, 3] = arr { 2 * } = mapper arr drop mapper drop" emit_am = asm
    "has _start" asm "_start:" assert_contains
}

# ============================================================================
# Run all tests
# ============================================================================

test_array_literal_type
test_array_literal_compiles
test_array_literal_emits
test_lambda_type
test_lambda_compiles
test_lambda_emits
test_fn_push_type
test_fn_call_compiles
test_array_and_lambda_compiles
test_array_and_lambda_emits
test_summary
