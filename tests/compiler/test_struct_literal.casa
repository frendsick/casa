fn test_unknown_field_error {
    "unknown_field_error" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "struct Point { x: int y: int }\nPoint { z: 1 y: 2 }" sl_parse drop
    "has errors" assert_has_errors
    "undefined name" ErrorKind::UndefinedName assert_error_kind
    clear_errors
    disable_test_mode
}

fn test_duplicate_field_error {
    "duplicate_field_error" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "struct Point { x: int y: int }\nPoint { x: 1 x: 2 y: 3 }" sl_parse drop
    "has errors" assert_has_errors
    "duplicate name" ErrorKind::DuplicateName assert_error_kind
    clear_errors
    disable_test_mode
}

fn test_unknown_field_mid_literal_error {
