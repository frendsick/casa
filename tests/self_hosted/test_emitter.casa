include "../../self_hosted/common.casa"
include "../../self_hosted/error.casa"
include "../../self_hosted/emitter.casa"
include "../../lib/test.casa"

# Helper: check that a string contains a substring
fn assert_contains needle:str haystack:str msg:str {
    haystack needle str::find = ac_pos
    if 0 ac_pos < then
        msg false assert_true
    else
        msg true assert_true
    fi
}

# Helper: build a minimal program with no bytecode
fn make_empty_program -> Program {
    0 0
    List::new (List[str])
    Map::new (Map[str List[Inst]])
    List::new (List[Inst])
    Program
}

# Helper: build a program with given bytecode and strings
fn make_simple_program bytecode:List[Inst] strings:List[str] globals:int constants:int -> Program {
    constants globals strings
    Map::new (Map[str List[Inst]])
    bytecode
    Program
}

fn test_sanitize_name {
    "sanitize_name" test_start
    "simple name" "foo" "foo" sanitize_name assert_str_eq
    "double colon" "Foo__bar" "Foo::bar" sanitize_name assert_str_eq
    "multiple" "A__B__C" "A::B::C" sanitize_name assert_str_eq
    "no colons" "hello_world" "hello_world" sanitize_name assert_str_eq
    "single colon preserved" "a:b" "a:b" sanitize_name assert_str_eq
}

fn test_escape_string {
    "escape_string" test_start
    "plain" "hello" "hello" escape_string assert_str_eq
    "newline" "a\\nb" "a\nb" escape_string assert_str_eq
    "tab" "a\\tb" "a\tb" escape_string assert_str_eq
    "backslash" "\\\\" "\\" escape_string assert_str_eq
    "quote" "\\\"" "\"" escape_string assert_str_eq
}

fn test_emit_bss {
    "emit_bss" test_start
    3 = bss_globals
    2 = bss_constants
    bss_constants bss_globals
    List::new (List[str])
    Map::new (Map[str List[Inst]])
    List::new (List[Inst])
    Program = bss_prog

    StringBuilder::new = bss_asm
    bss_prog bss_asm emit_bss
    bss_asm .build = bss_result

    "has bss section" bss_result ".section .bss" assert_contains
    "has globals" bss_result "globals: .skip 24" assert_contains
    "has constants" bss_result "constants: .skip 16" assert_contains
    "has return stack" bss_result "return_stack: .skip 65536" assert_contains
    "has heap" bss_result "heap: .skip 67108864" assert_contains
    "has heap_ptr" bss_result "heap_ptr: .skip 8" assert_contains
    "has argc" bss_result "__argc: .skip 8" assert_contains
    "has argv" bss_result "__argv: .skip 8" assert_contains
    "has print_buf" bss_result "print_buf: .skip 32" assert_contains
}

fn test_emit_data {
    "emit_data" test_start
    List::new (List[str]) = data_strings
    "hello" data_strings .push
    "world" data_strings .push

    0 0 data_strings
    Map::new (Map[str List[Inst]])
    List::new (List[Inst])
    Program = data_prog

    StringBuilder::new = data_asm
    data_prog data_asm emit_data
    data_asm .build = data_result

    "has data section" data_result ".section .data" assert_contains
    "has str_0 label" data_result "str_0:" assert_contains
    "has str_1 label" data_result "str_1:" assert_contains
    "has quad 5 for hello" data_result ".quad 5" assert_contains
    "has hello ascii" data_result ".asciz \"hello\"" assert_contains
    "has quad 5 for world" data_result ".quad 5" assert_contains
    "has bool_true" data_result "bool_true:" assert_contains
    "has bool_false" data_result "bool_false:" assert_contains
}

fn test_emit_push {
    "emit_push" test_start
    List::new (List[Inst]) = push_bc
    42 InstKind::InstPush (int) make_inst_int push_bc .push

    0 0 List::new (List[str])
    Map::new (Map[str List[Inst]])
    push_bc
    Program = push_prog

    push_prog emit = push_result
    "has pushq $42" push_result "pushq $42" assert_contains
}

fn test_emit_push_str {
    "emit_push_str" test_start
    List::new (List[Inst]) = ps_bc
    0 InstKind::InstPushStr (int) make_inst_int ps_bc .push

    List::new (List[str]) = ps_strings
    "test" ps_strings .push

    0 0 ps_strings
    Map::new (Map[str List[Inst]])
    ps_bc
    Program = ps_prog

    ps_prog emit = ps_result
    "has str_0 ref" ps_result "str_0(%rip)" assert_contains
}

