fn test_emit_full_program {
    "emit_full_program" test_start
    # Emit a program with one PUSH instruction
    List::new (List[Inst]) = fp_bc
    99 InstKind::InstPush (int) make_inst_int fp_bc .push

    0 0 List::new (List[str])
    Map::new (Map[str List[Inst]])
    fp_bc
    Program = fp_prog

    fp_prog emit = fp_result
    "has bss" fp_result ".section .bss" assert_contains
    "has data" fp_result ".section .data" assert_contains
    "has text" fp_result ".section .text" assert_contains
    "has push 99" fp_result "pushq $99" assert_contains
}

