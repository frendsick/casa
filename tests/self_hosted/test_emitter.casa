fn test_emit_fn_call {
    "emit_fn_call" test_start
    List::new (List[Inst]) = fc_bc
    "my_func" InstKind::InstFnCall (int) make_inst_str fc_bc .push

    List::new (List[Inst]) = fc_fn_bc

    Map::new (Map[str List[Inst]]) = fc_fns
    "my_func" fc_fn_bc fc_fns .set = fc_fns

    0 0 List::new (List[str]) fc_fns fc_bc Program = fc_prog
    fc_prog emit = fc_result
    "has jmp fn_my_func" fc_result "jmp fn_my_func" assert_contains
    "has fn_my_func label" fc_result "fn_my_func:" assert_contains
}

fn test_emit_fn_call_sanitized {
    "emit_fn_call_sanitized" test_start
    List::new (List[Inst]) = fcs_bc
    "Foo::bar" InstKind::InstFnCall (int) make_inst_str fcs_bc .push

    List::new (List[Inst]) = fcs_fn_bc
    Map::new (Map[str List[Inst]]) = fcs_fns
    "Foo::bar" fcs_fn_bc fcs_fns .set = fcs_fns

    0 0 List::new (List[str]) fcs_fns fcs_bc Program = fcs_prog
    fcs_prog emit = fcs_result
    "has jmp fn_Foo__bar" fcs_result "jmp fn_Foo__bar" assert_contains
    "has fn_Foo__bar label" fcs_result "fn_Foo__bar:" assert_contains
}

fn test_emit_start_section {
    "emit_start_section" test_start
    make_empty_program emit = es_result
    "has _start label" es_result "_start:" assert_contains
    "has globl" es_result ".globl _start" assert_contains
    "has return_stack init" es_result "leaq return_stack(%rip), %r14" assert_contains
    "has exit syscall" es_result "movq $60, %rax" assert_contains
}

fn test_emit_helpers_present {
    "emit_helpers_present" test_start
    make_empty_program emit = eh_result
    "has print_int" eh_result "print_int:" assert_contains
    "has print_str" eh_result "print_str:" assert_contains
    "has str_concat" eh_result "str_concat:" assert_contains
}

fn test_emit_comparison {
    "emit_comparison" test_start
