# Locals
# ---------------------------------------------------------------------------

fn test_emit_locals {
    "emit_locals" test_start

    "fn foo a:int -> int { a } 5 foo" emit_source = asm
    "(%r14)" "(%r14)" asm assert_contains
    "rep stosq" "rep stosq" asm assert_contains
}

