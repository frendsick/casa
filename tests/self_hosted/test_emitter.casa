fn test_emit_local_ops {
    "emit_local_ops" test_start
    List::new (List[Inst]) = lo_bc
    3 InstKind::InstLocalsInit (int) make_inst_int lo_bc .push
    0 InstKind::InstLocalGet (int) make_inst_int lo_bc .push
    1 InstKind::InstLocalSet (int) make_inst_int lo_bc .push
    3 InstKind::InstLocalsUninit (int) make_inst_int lo_bc .push

    0 0 List::new (List[str])
    Map::new (Map[str List[Inst]])
    lo_bc
    Program = lo_prog

    lo_prog emit = lo_result
    "has locals init count" lo_result "movq $3, %rcx" assert_contains
    "has locals init add" lo_result "addq $24, %r14" assert_contains
    "has local get offset" lo_result "movq -8(%r14), %rax" assert_contains
    "has local set offset" lo_result "movq %rax, -16(%r14)" assert_contains
    "has locals uninit" lo_result "subq $24, %r14" assert_contains
}

