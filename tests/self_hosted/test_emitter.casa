    "has popq rax" sc_result "popq %rax" assert_contains
    "has popq rdi" sc_result "popq %rdi" assert_contains
    "has popq rsi" sc_result "popq %rsi" assert_contains
    "has popq rdx" sc_result "popq %rdx" assert_contains
    "has syscall" sc_result "    syscall" assert_contains
