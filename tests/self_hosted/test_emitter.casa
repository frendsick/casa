fn test_emit_fn_call {
    "emit_fn_call" test_start
    List::new (List[Inst]) = fc_bc
    "my_func" InstKind::InstFnCall (int) make_inst_str fc_bc .push

    List::new (List[Inst]) = fc_fn_bc

    Map::new (Map[str List[Inst]]) = fc_fns
    "my_func" fc_fn_bc fc_fns .set = fc_fns

    0 0 List::new (List[str]) fc_fns fc_bc Program = fc_prog
    fc_prog emit = fc_result
    "has jmp fn_my_func" fc_result "jmp fn_my_func" assert_contains
    "has fn_my_func label" fc_result "fn_my_func:" assert_contains
}

