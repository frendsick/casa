# ---------------------------------------------------------------------------
# Function operations
# ---------------------------------------------------------------------------

fn test_emit_fn_return {
    "emit_fn_return" test_start
    # In a non-global context, fn_return emits jmpq *(%r14)
    List::new (List[Inst]) = fr_bc
    InstKind::InstFnReturn (int) make_inst fr_bc .push

    List::new (List[Inst]) = fr_fn_bc
    InstKind::InstFnReturn (int) make_inst fr_fn_bc .push

    Map::new (Map[str List[Inst]]) = fr_fns
    "test_fn" fr_fn_bc fr_fns .set = fr_fns

    0 0 List::new (List[str]) fr_fns fr_bc Program = fr_prog
    fr_prog emit = fr_result
    "has jmpq *(%r14)" fr_result "jmpq *(%r14)" assert_contains
}

fn test_emit_fn_exec {
    "emit_fn_exec" test_start
    List::new (List[Inst]) = fe_bc
    InstKind::InstFnExec (int) make_inst fe_bc .push

    0 0 List::new (List[str])
    Map::new (Map[str List[Inst]])
    fe_bc
    Program = fe_prog

    fe_prog emit = fe_result
    "has jmpq *%rax" fe_result "jmpq *%rax" assert_contains
}

fn test_emit_fn_push {
    "emit_fn_push" test_start
    List::new (List[Inst]) = fp_bc
    "my_lambda" InstKind::InstFnPush (int) make_inst_str fp_bc .push

    List::new (List[Inst]) = fp_fn_bc
    Map::new (Map[str List[Inst]]) = fp_fns
    "my_lambda" fp_fn_bc fp_fns .set = fp_fns

    0 0 List::new (List[str]) fp_fns fp_bc Program = fp_prog
    fp_prog emit = fp_result
    "has leaq fn_my_lambda" fp_result "leaq fn_my_lambda" assert_contains
}

