}

# ============================================================================
# Hidden params for trait bounds
# ============================================================================

fn test_trait_hidden_params_prepended {
    "trait_hidden_params_prepended" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = func
    0 = hidden_count
    0 = index
    while index func Function::signature Signature::parameters .length > do
        index func Function::signature Signature::parameters .get Parameter::name = param_name
        if param_name "__trait_" str::starts_with then
            1 += hidden_count
        fi
        1 += index
    done
    "one hidden param" 1 hidden_count assert_eq
}

fn test_trait_hidden_param_name {
    "trait_hidden_param_name" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = func
    false = found
    0 = index
    while index func Function::signature Signature::parameters .length > do
        if "__trait_K_hash" index func Function::signature Signature::parameters .get Parameter::name == then
            true = found
        fi
        1 += index
    done
    "found __trait_K_hash" found assert_true
}

fn test_trait_hidden_param_type {
    "trait_hidden_param_type" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = func
    0 = index
    while index func Function::signature Signature::parameters .length > do
        index func Function::signature Signature::parameters .get = param
        if "__trait_K_hash" param Parameter::name == then
            "type" "fn[K -> int]" param Parameter::typ assert_str_eq
        fi
        1 += index
    done
}

fn test_trait_two_methods_hidden_params {
    "trait_two_methods_hidden_params" test_start
    HASHABLE_TRAIT "fn tbtest[K: Hashable] K -> int { .hash }" str::concat trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = func
    0 = hidden_count
    false = has_hash
    false = has_eq
    0 = index
    while index func Function::signature Signature::parameters .length > do
        index func Function::signature Signature::parameters .get Parameter::name = param_name
        if param_name "__trait_" str::starts_with then
            1 += hidden_count
            if "__trait_K_hash" param_name == then true = has_hash fi
            if "__trait_K_eq" param_name == then true = has_eq fi
        fi
        1 += index
    done
    "two hidden params" 2 hidden_count assert_eq
    "has hash" has_hash assert_true
    "has eq" has_eq assert_true
}

fn test_trait_hidden_params_correct_types {
    "trait_hidden_params_correct_types" test_start
    HASHABLE_TRAIT "fn tbtest[K: Hashable] K -> int { .hash }" str::concat trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = func
    0 = index
    while index func Function::signature Signature::parameters .length > do
        index func Function::signature Signature::parameters .get = param
        if "__trait_K_hash" param Parameter::name == then
            "hash type" "fn[K -> int]" param Parameter::typ assert_str_eq
        fi
        if "__trait_K_eq" param Parameter::name == then
            "eq type" "fn[K K -> bool]" param Parameter::typ assert_str_eq
        fi
        1 += index
    done
}

fn test_trait_hidden_params_creates_variables {
    "trait_hidden_params_creates_variables" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = func
    false = found
    0 = index
    while index func Function::variables .length > do
        if "__trait_K_hash" index func Function::variables .get Variable::name == then
            true = found
        fi
        1 += index
    done
    "found variable" found assert_true
}

fn test_trait_hidden_params_creates_assign_ops {
    "trait_hidden_params_creates_assign_ops" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = func
    false = found
    0 = index
    while index func Function::ops .length > do
        index func Function::ops .get = current_op
        if
            OpKind::OpAssignVar current_op Op::kind ==
            "__trait_K_hash" current_op Op::value (str) == &&
        then
            true = found
        fi
        1 += index
    done
    "found assign op" found assert_true
}

