fn test_trait_empty {
    "trait_empty" test_start
    "trait Empty { }" trait_test_parse drop
    "registered" "Empty" GLOBAL_TRAITS .get .is_some assert_true
    "no methods" 0 "Empty" GLOBAL_TRAITS .get .unwrap CasaTrait::methods .length assert_eq
}

fn test_trait_single_method {
    "trait_single_method" test_start
    "trait Printable { fn to_str self:self -> str }" trait_test_parse drop
    "Printable" GLOBAL_TRAITS .get .unwrap = tsm_trait
    "method count" 1 tsm_trait CasaTrait::methods .length assert_eq
    "method name" "to_str" 0 tsm_trait CasaTrait::methods .get TraitMethod::name assert_str_eq
}

fn test_trait_has_location {
    "trait_has_location" test_start
    "trait MyTrait { fn do_thing self:self -> int }" trait_test_parse drop
    "has file" "" "MyTrait" GLOBAL_TRAITS .get .unwrap CasaTrait::location Location::file != assert_true
}

# ============================================================================
# Trait parsing errors
# ============================================================================


fn test_trait_unclosed_block_raises {
    "trait_unclosed_block_raises" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "trait Foo { fn bar self:self -> int" trait_test_parse drop
    "has errors" assert_has_errors
    clear_errors
    disable_test_mode
}

fn test_trait_unexpected_token_raises {
    "trait_unexpected_token_raises" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "trait Foo { 42 }" trait_test_parse drop
    "has errors" assert_has_errors
    "unexpected token" ErrorKind::UnexpectedToken (int) assert_error_kind
    clear_errors
    disable_test_mode
}

fn test_trait_duplicate_raises {
    "trait_duplicate_raises" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "trait Foo { fn bar self:self -> int }\ntrait Foo { fn baz self:self -> int }\n" trait_test_parse drop
    "has errors" assert_has_errors
    "duplicate name" ErrorKind::DuplicateName (int) assert_error_kind
    clear_errors
    disable_test_mode
}

# ============================================================================
# Trait bounds parsing
# ============================================================================

fn test_trait_bound_basic {
    "trait_bound_basic" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = tbb_fn
    "K in type_vars" "K" tbb_fn Function::signature Signature::type_vars .has assert_true
    "K bound" "Hashable" "K" tbb_fn Function::signature Signature::trait_bounds .get .unwrap assert_str_eq
}

fn test_trait_bound_with_unbounded_var {
    "trait_bound_with_unbounded_var" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable, V] K V -> int { drop .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = tbw_fn
    "K in vars" "K" tbw_fn Function::signature Signature::type_vars .has assert_true
    "V in vars" "V" tbw_fn Function::signature Signature::type_vars .has assert_true
    "K bound" "Hashable" "K" tbw_fn Function::signature Signature::trait_bounds .get .unwrap assert_str_eq
    "V no bound" "V" tbw_fn Function::signature Signature::trait_bounds .get .is_none assert_true
}

fn test_trait_bound_multiple_bounded {
    "trait_bound_multiple_bounded" test_start
    "trait Hashable { fn hash self:self -> int }\ntrait Printable { fn to_str self:self -> str }\nfn tbtest[K: Hashable, V: Printable] K V -> int { .to_str drop .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = tbm_fn
    "K bound" "Hashable" "K" tbm_fn Function::signature Signature::trait_bounds .get .unwrap assert_str_eq
    "V bound" "Printable" "V" tbm_fn Function::signature Signature::trait_bounds .get .unwrap assert_str_eq
}

fn test_trait_bound_undefined_raises {
    "trait_bound_undefined_raises" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "fn tbtest[K: Nonexistent] K -> int { 0 }" trait_test_parse drop
    "has errors" assert_has_errors
    "undefined name" ErrorKind::UndefinedName (int) assert_error_kind
    clear_errors
    disable_test_mode
}

# ============================================================================
# Hidden params for trait bounds
# ============================================================================

fn test_trait_hidden_params_prepended {
    "trait_hidden_params_prepended" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = thp_fn
    0 = thp_hidden_count
    0 = thp_i
    while thp_i thp_fn Function::signature Signature::parameters .length > do
        thp_i thp_fn Function::signature Signature::parameters .get Parameter::name = thp_pname
        if thp_pname "__trait_" str::starts_with then
            1 += thp_hidden_count
        fi
        1 += thp_i
    done
    "one hidden param" 1 thp_hidden_count assert_eq
}

fn test_trait_hidden_param_name {
    "trait_hidden_param_name" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = thn_fn
    false = thn_found
    0 = thn_i
    while thn_i thn_fn Function::signature Signature::parameters .length > do
        if "__trait_K_hash" thn_i thn_fn Function::signature Signature::parameters .get Parameter::name == then
            true = thn_found
        fi
        1 += thn_i
    done
    "found __trait_K_hash" thn_found assert_true
}

fn test_trait_hidden_param_type {
    "trait_hidden_param_type" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = tht_fn
    0 = tht_i
    while tht_i tht_fn Function::signature Signature::parameters .length > do
        tht_i tht_fn Function::signature Signature::parameters .get = tht_param
        if "__trait_K_hash" tht_param Parameter::name == then
            "type" "fn[K -> int]" tht_param Parameter::typ assert_str_eq
        fi
        1 += tht_i
    done
}

fn test_trait_two_methods_hidden_params {
    "trait_two_methods_hidden_params" test_start
    HASHABLE_TRAIT "fn tbtest[K: Hashable] K -> int { .hash }" str::concat trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = ttm_fn
    0 = ttm_hidden_count
    false = ttm_has_hash
    false = ttm_has_eq
    0 = ttm_i
    while ttm_i ttm_fn Function::signature Signature::parameters .length > do
        ttm_i ttm_fn Function::signature Signature::parameters .get Parameter::name = ttm_pname
        if ttm_pname "__trait_" str::starts_with then
            1 += ttm_hidden_count
            if "__trait_K_hash" ttm_pname == then true = ttm_has_hash fi
            if "__trait_K_eq" ttm_pname == then true = ttm_has_eq fi
        fi
        1 += ttm_i
    done
    "two hidden params" 2 ttm_hidden_count assert_eq
    "has hash" ttm_has_hash assert_true
    "has eq" ttm_has_eq assert_true
}

fn test_trait_hidden_params_correct_types {
    "trait_hidden_params_correct_types" test_start
    HASHABLE_TRAIT "fn tbtest[K: Hashable] K -> int { .hash }" str::concat trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = thc_fn
    0 = thc_i
    while thc_i thc_fn Function::signature Signature::parameters .length > do
        thc_i thc_fn Function::signature Signature::parameters .get = thc_param
        if "__trait_K_hash" thc_param Parameter::name == then
            "hash type" "fn[K -> int]" thc_param Parameter::typ assert_str_eq
        fi
        if "__trait_K_eq" thc_param Parameter::name == then
            "eq type" "fn[K K -> bool]" thc_param Parameter::typ assert_str_eq
        fi
        1 += thc_i
    done
}

fn test_trait_hidden_params_creates_variables {
    "trait_hidden_params_creates_variables" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = thv_fn
    false = thv_found
    0 = thv_i
    while thv_i thv_fn Function::variables .length > do
        if "__trait_K_hash" thv_i thv_fn Function::variables .get Variable::name == then
            true = thv_found
        fi
        1 += thv_i
    done
    "found variable" thv_found assert_true
}

fn test_trait_hidden_params_creates_assign_ops {
    "trait_hidden_params_creates_assign_ops" test_start
    "trait Hashable { fn hash self:self -> int }\nfn tbtest[K: Hashable] K -> int { .hash }" trait_test_parse drop
    "tbtest" GLOBAL_FUNCTIONS .get .unwrap = tha_fn
    false = tha_found
    0 = tha_i
    while tha_i tha_fn Function::ops .length > do
        tha_i tha_fn Function::ops .get = tha_op
        if
            OpKind::OpAssignVar (int) tha_op Op::kind ==
            "__trait_K_hash" tha_op Op::value (str) == &&
        then
            true = tha_found
        fi
        1 += tha_i
    done
    "found assign op" tha_found assert_true
}

# ============================================================================
# Type satisfaction
# ============================================================================

fn test_struct_with_impl_satisfies {
    "struct_with_impl_satisfies" test_start
    HASHABLE_TRAIT "struct Foo { val: int }\nimpl Foo { fn hash self:Foo -> int { self Foo::val } fn eq self:Foo other:Foo -> bool { self Foo::val other Foo::val == } }\n" str::concat trait_test_resolve drop
    "satisfies" Option::None (Option[Function]) "Hashable" "Foo" type_satisfies_trait assert_true
}

fn test_struct_without_impl_does_not_satisfy {
    "struct_without_impl_does_not_satisfy" test_start
    HASHABLE_TRAIT "struct Bar { val: int }\n" str::concat trait_test_resolve drop
    "does not satisfy" Option::None (Option[Function]) "Hashable" "Bar" type_satisfies_trait ! assert_true
}

fn test_partial_impl_does_not_satisfy {
    "partial_impl_does_not_satisfy" test_start
    HASHABLE_TRAIT "struct Baz { val: int }\nimpl Baz { fn hash self:Baz -> int { self Baz::val } }\n" str::concat trait_test_resolve drop
    "does not satisfy" Option::None (Option[Function]) "Hashable" "Baz" type_satisfies_trait ! assert_true
}

fn test_undefined_trait_returns_false {
    "undefined_trait_returns_false" test_start
    clear_global_state
    "does not satisfy" Option::None (Option[Function]) "Nonexistent" "int" type_satisfies_trait ! assert_true
}

