include "../../self_hosted/common.casa"
include "../../self_hosted/error.casa"
include "../../lib/test.casa"

fn test_offset_to_line_col {
    "offset_to_line_col" test_start
    "hello\nworld" = source
    "line 1 at 0" 1 0 source offset_to_line_col assert_eq
    "line 1 at 4" 1 4 source offset_to_line_col assert_eq
    "line 2 at 6" 2 6 source offset_to_line_col assert_eq
    "line 2 at 10" 2 10 source offset_to_line_col assert_eq
}

fn test_offset_to_line_col_middle_of_first_line {
    "offset_to_line_col_middle_of_first_line" test_start
    "hello world" = source
    "line" 1 6 source offset_to_line_col assert_eq
    "col" 7 6 source offset_to_col assert_eq
    "source line" "hello world" 6 source offset_to_source_line assert_str_eq
}

fn test_offset_to_line_col_third_line {
    "offset_to_line_col_third_line" test_start
    "abc\ndef\nghi" = source
    "line" 3 9 source offset_to_line_col assert_eq
    "col" 2 9 source offset_to_col assert_eq
    "source line" "ghi" 9 source offset_to_source_line assert_str_eq
}

fn test_offset_to_line_col_end_of_source {
    "offset_to_line_col_end_of_source" test_start
    "abc\ndef" = source
    "line" 2 7 source offset_to_line_col assert_eq
    "col" 4 7 source offset_to_col assert_eq
    "source line" "def" 7 source offset_to_source_line assert_str_eq
}

fn test_offset_to_col {
    "offset_to_col" test_start
    "hello\nworld" = source
    "col 1 at 0" 1 0 source offset_to_col assert_eq
    "col 5 at 4" 5 4 source offset_to_col assert_eq
    "col 1 at 6" 1 6 source offset_to_col assert_eq
    "col 3 at 8" 3 8 source offset_to_col assert_eq
}

fn test_offset_to_source_line {
    "offset_to_source_line" test_start
    "hello\nworld" = source
    "first line" "hello" 3 source offset_to_source_line assert_str_eq
    "second line" "world" 8 source offset_to_source_line assert_str_eq
}

fn test_error_kind_name {
    "error_kind_name" test_start
    "syntax" "SYNTAX" ErrorKind::Syntax (int) error_kind_name assert_str_eq
    "type mismatch" "TYPE_MISMATCH" ErrorKind::TypeMismatch (int) error_kind_name assert_str_eq
    "undefined" "UNDEFINED_NAME" ErrorKind::UndefinedName (int) error_kind_name assert_str_eq
}

fn test_format_error_no_location {
    "format_error_no_location" test_start
    empty_location "bad token" ErrorKind::Syntax (int) make_error = err
    err format_error = formatted
    "exact format" "error[SYNTAX]: bad token" formatted assert_str_eq
}

fn test_format_error_with_location_no_source {
    "format_error_with_location_no_source" test_start
    3 0 "test.casa" make_location "not found" ErrorKind::UndefinedName (int) make_error = err
    err format_error = formatted
    "has error kind" formatted "error[UNDEFINED_NAME]" str::find 0 1 - swap > assert_true
}

fn test_format_error_with_source {
    "format_error_with_source" test_start
    "test_src.casa" "foo bar baz" SOURCE_CACHE .set = SOURCE_CACHE
    3 4 "test_src.casa" make_location "`bar` is not defined" ErrorKind::UndefinedName (int) make_error = err
    err format_error = formatted
    "has error kind" formatted "error[UNDEFINED_NAME]" str::find 0 1 - swap > assert_true
    "has location" formatted "test_src.casa:1:5" str::find 0 1 - swap > assert_true
    "has source line" formatted "foo bar baz" str::find 0 1 - swap > assert_true
    "has carets" formatted "^^^" str::find 0 1 - swap > assert_true
}

fn test_format_error_multiline_source {
    "format_error_multiline_source" test_start
    "test_multi.casa" "10 = x\nfoo\n20 = y" SOURCE_CACHE .set = SOURCE_CACHE
    3 7 "test_multi.casa" make_location "`foo` is not defined" ErrorKind::UndefinedName (int) make_error = err
    err format_error = formatted
    "has location" formatted "test_multi.casa:2:1" str::find 0 1 - swap > assert_true
    "has foo" formatted "foo" str::find 0 1 - swap > assert_true
    "has carets" formatted "^^^" str::find 0 1 - swap > assert_true
}

fn test_format_error_with_expected_got {
    "format_error_with_expected_got" test_start
    "`str`" "`int`" empty_location "Type mismatch" ErrorKind::TypeMismatch (int) make_error_expected = err
    err format_error = formatted
    "has expected" formatted "Expected: `int`" str::find 0 1 - swap > assert_true
    "has got" formatted "Got: `str`" str::find 0 1 - swap > assert_true
}

fn test_format_error_with_note {
    "format_error_with_note" test_start
    "test_note.casa" "\"hello\" 42 +" SOURCE_CACHE .set = SOURCE_CACHE
    2 8 "test_note.casa" make_location "Type mismatch" ErrorKind::TypeMismatch (int) make_error = err
    7 0 "test_note.casa" make_location "value of type `str` pushed here" CasaNote = note
    note err CasaError::notes .push
    err format_error = formatted
    "has Note prefix" formatted "Note: value of type `str` pushed here" str::find 0 1 - swap > assert_true
    "has note location" formatted "test_note.casa:1:1" str::find 0 1 - swap > assert_true
}

fn test_format_error_with_multiple_notes {
    "format_error_with_multiple_notes" test_start
    "test_notes.casa" "if true then\n    1 2\nelse\n    3\nfi" SOURCE_CACHE .set = SOURCE_CACHE
    2 30 "test_notes.casa" make_location "Branches have incompatible stack effects" ErrorKind::StackMismatch (int) make_error = err
    2 0 "test_notes.casa" make_location "`if` branch has signature `None -> int int`" CasaNote = note1
    4 21 "test_notes.casa" make_location "`else` branch has signature `None -> int`" CasaNote = note2
    note1 err CasaError::notes .push
    note2 err CasaError::notes .push
    err format_error = formatted
    "has message" formatted "Branches have incompatible stack effects" str::find 0 1 - swap > assert_true
    "has if note" formatted "`if` branch has signature" str::find 0 1 - swap > assert_true
    "has else note" formatted "`else` branch has signature" str::find 0 1 - swap > assert_true
    # Check that "Note:" appears at least twice by finding second occurrence
    formatted "Note:" str::find = first_note_pos
    "has first Note" 0 1 - first_note_pos > assert_true
    formatted first_note_pos 5 + formatted .length first_note_pos 5 + - str::substring = after_first
    "has second Note" after_first "Note:" str::find 0 1 - swap > assert_true
}

fn test_format_error_note_without_source {
    "format_error_note_without_source" test_start
    "present.casa" "foo" SOURCE_CACHE .set = SOURCE_CACHE
    3 0 "present.casa" make_location "Type mismatch" ErrorKind::TypeMismatch (int) make_error = err
    5 0 "missing.casa" make_location "value pushed here" CasaNote = note
    note err CasaError::notes .push
    err format_error = formatted
    "has Note prefix" formatted "Note: value pushed here" str::find 0 1 - swap > assert_true
    # missing.casa is not in source cache, so its filename should not appear in context
    formatted "Note: value pushed here" str::find = note_pos
    # The note message is there but no source context for missing.casa
    # Check that "missing.casa" does not appear after the note
    formatted note_pos 23 + formatted .length note_pos 23 + - str::substring = after_note
    "no missing.casa context" 0 after_note "missing.casa" str::find < assert_true
}

fn test_format_source_context_basic {
    "format_source_context_basic" test_start
    3 4 "foo bar baz" "ctx.casa" format_source_context = ctx
    "has location" ctx "ctx.casa:1:5" str::find 0 1 - swap > assert_true
    "has source" ctx "foo bar baz" str::find 0 1 - swap > assert_true
    "has carets" ctx "^^^" str::find 0 1 - swap > assert_true
}

