fn test_compile_more_direct_ops {
    "compile_more_direct_ops" test_start
    reset_labels
    List::new (List[Op]) = mdo_ops
    OpKind::OpMul (int) 0 test_make_op mdo_ops .push
    OpKind::OpDiv (int) 0 test_make_op mdo_ops .push
    OpKind::OpMod (int) 0 test_make_op mdo_ops .push
    OpKind::OpShl (int) 0 test_make_op mdo_ops .push
    OpKind::OpShr (int) 0 test_make_op mdo_ops .push
    OpKind::OpAnd (int) 0 test_make_op mdo_ops .push
    OpKind::OpOr (int) 0 test_make_op mdo_ops .push
    OpKind::OpNot (int) 0 test_make_op mdo_ops .push
    OpKind::OpEq (int) 0 test_make_op mdo_ops .push
    OpKind::OpNe (int) 0 test_make_op mdo_ops .push
    OpKind::OpGt (int) 0 test_make_op mdo_ops .push
    OpKind::OpGe (int) 0 test_make_op mdo_ops .push
    OpKind::OpLt (int) 0 test_make_op mdo_ops .push
    OpKind::OpLe (int) 0 test_make_op mdo_ops .push
    OpKind::OpSwap (int) 0 test_make_op mdo_ops .push
    OpKind::OpOver (int) 0 test_make_op mdo_ops .push
    OpKind::OpRot (int) 0 test_make_op mdo_ops .push

    mdo_ops make_compiler = mdo_compiler
    List::new (List[Inst]) = mdo_bytecode
    mdo_bytecode mdo_compiler compile_ops

    # Index 0 is label
    "mul inst" InstKind::InstMul (int) 1 mdo_bytecode .get Inst::kind assert_eq
    "div inst" InstKind::InstDiv (int) 2 mdo_bytecode .get Inst::kind assert_eq
    "mod inst" InstKind::InstMod (int) 3 mdo_bytecode .get Inst::kind assert_eq
    "shl inst" InstKind::InstShl (int) 4 mdo_bytecode .get Inst::kind assert_eq
    "shr inst" InstKind::InstShr (int) 5 mdo_bytecode .get Inst::kind assert_eq
    "and inst" InstKind::InstAnd (int) 6 mdo_bytecode .get Inst::kind assert_eq
    "or inst" InstKind::InstOr (int) 7 mdo_bytecode .get Inst::kind assert_eq
    "not inst" InstKind::InstNot (int) 8 mdo_bytecode .get Inst::kind assert_eq
    "eq inst" InstKind::InstEq (int) 9 mdo_bytecode .get Inst::kind assert_eq
    "ne inst" InstKind::InstNe (int) 10 mdo_bytecode .get Inst::kind assert_eq
    "gt inst" InstKind::InstGt (int) 11 mdo_bytecode .get Inst::kind assert_eq
    "ge inst" InstKind::InstGe (int) 12 mdo_bytecode .get Inst::kind assert_eq
    "lt inst" InstKind::InstLt (int) 13 mdo_bytecode .get Inst::kind assert_eq
    "le inst" InstKind::InstLe (int) 14 mdo_bytecode .get Inst::kind assert_eq
    "swap inst" InstKind::InstSwap (int) 15 mdo_bytecode .get Inst::kind assert_eq
    "over inst" InstKind::InstOver (int) 16 mdo_bytecode .get Inst::kind assert_eq
    "rot inst" InstKind::InstRot (int) 17 mdo_bytecode .get Inst::kind assert_eq
}

