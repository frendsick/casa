fn test_compile_direct_ops_print {
    "compile_direct_ops_print" test_start
    reset_labels
    List::new (List[Op]) = dop_ops
    OpKind::OpPrintInt (int) 0 test_make_op dop_ops .push
    OpKind::OpPrintStr (int) 0 test_make_op dop_ops .push
    OpKind::OpPrintChar (int) 0 test_make_op dop_ops .push
    OpKind::OpPrintCstr (int) 0 test_make_op dop_ops .push
