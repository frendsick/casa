fn test_compile_type_cast_no_output {
    "compile_type_cast_no_output" test_start
    reset_labels
    List::new (List[Op]) = ctc_ops
    OpKind::OpTypeCast (int) 0 test_make_op ctc_ops .push

    ctc_ops make_compiler = ctc_compiler
    List::new (List[Inst]) = ctc_bytecode
    ctc_bytecode ctc_compiler compile_ops

    # Only the label should be emitted, no instruction for type cast
    "type cast produces no inst" 1 ctc_bytecode .length assert_eq
}

fn test_compile_include_no_output {
    "compile_include_no_output" test_start
    reset_labels
    List::new (List[Op]) = cin_ops
    OpKind::OpIncludeFile (int) 0 test_make_op cin_ops .push

    cin_ops make_compiler = cin_compiler
    List::new (List[Inst]) = cin_bytecode
    cin_bytecode cin_compiler compile_ops

    "include produces no inst" 1 cin_bytecode .length assert_eq
}

fn test_op_index_to_label_stability {
    "op_index_to_label_stability" test_start
    reset_labels
    42 op_index_to_label = stable_first
    42 op_index_to_label = stable_second
    "same index same label" stable_first stable_second assert_eq
    99 op_index_to_label = other_label
    "different index different label" stable_first other_label != assert_true
}

fn test_compile_if_block {
    "compile_if_block" test_start
    reset_labels
    List::new (List[Op]) = tib_ops
    OpKind::OpIfStart (int) 0 test_make_op tib_ops .push
    OpKind::OpIfCondition (int) 0 test_make_op tib_ops .push
    OpKind::OpIfEnd (int) 0 test_make_op tib_ops .push

    "ops has 3 elements" 3 tib_ops .length assert_eq
    "op 0 is if_start" OpKind::OpIfStart (int) 0 tib_ops .get Op::kind assert_eq
    "op 2 is if_end" OpKind::OpIfEnd (int) 2 tib_ops .get Op::kind assert_eq

    tib_ops make_compiler = tib_compiler
    List::new (List[Inst]) = tib_bytecode
    tib_bytecode tib_compiler compile_ops

    # Expected: LABEL, JUMP_NE(end_label), LABEL(end_label)
    "if block bytecode length" 3 tib_bytecode .length assert_eq
    "if block has label" InstKind::InstLabel (int) 0 tib_bytecode .get Inst::kind assert_eq
    "if condition jump_ne" InstKind::InstJumpNe (int) 1 tib_bytecode .get Inst::kind assert_eq
    "if end label" InstKind::InstLabel (int) 2 tib_bytecode .get Inst::kind assert_eq
}

fn test_compile_while_block {
    "compile_while_block" test_start
    reset_labels
    List::new (List[Op]) = twb_ops
    OpKind::OpWhileStart (int) 0 test_make_op twb_ops .push
    OpKind::OpWhileCondition (int) 0 test_make_op twb_ops .push
    OpKind::OpWhileEnd (int) 0 test_make_op twb_ops .push

    twb_ops make_compiler = twb_compiler
    List::new (List[Inst]) = twb_bytecode
    twb_bytecode twb_compiler compile_ops

    # Expected: LABEL(fn), LABEL(start), JUMP_NE(end), JUMP(start), LABEL(end)
    "while block bytecode length" 5 twb_bytecode .length assert_eq
    "while fn label" InstKind::InstLabel (int) 0 twb_bytecode .get Inst::kind assert_eq
    "while start label" InstKind::InstLabel (int) 1 twb_bytecode .get Inst::kind assert_eq
    "while condition jump_ne" InstKind::InstJumpNe (int) 2 twb_bytecode .get Inst::kind assert_eq
    "while end jump" InstKind::InstJump (int) 3 twb_bytecode .get Inst::kind assert_eq
    "while end label" InstKind::InstLabel (int) 4 twb_bytecode .get Inst::kind assert_eq
}

fn test_compile_string_eq {
    "compile_string_eq" test_start
    reset_labels
    List::new (List[Op]) = cse_ops
    # make_op_annotated value:int kind:int location:Location annotation:str
    "str" OpKind::OpEq (int) 0 test_make_op_annotated cse_ops .push

    cse_ops make_compiler = cse_compiler
    List::new (List[Inst]) = cse_bytecode
    cse_bytecode cse_compiler compile_ops

    "str_eq inst" InstKind::InstStrEq (int) 1 cse_bytecode .get Inst::kind assert_eq
}

fn test_compile_string_ne {
    "compile_string_ne" test_start
    reset_labels
    List::new (List[Op]) = csne_ops
    "str" OpKind::OpNe (int) 0 test_make_op_annotated csne_ops .push

    csne_ops make_compiler = csne_compiler
    List::new (List[Inst]) = csne_bytecode
    csne_bytecode csne_compiler compile_ops

    # Should emit STR_EQ + NOT
    "str_ne has str_eq" InstKind::InstStrEq (int) 1 csne_bytecode .get Inst::kind assert_eq
    "str_ne has not" InstKind::InstNot (int) 2 csne_bytecode .get Inst::kind assert_eq
}

fn test_compile_assign_increment {
    "compile_assign_increment" test_start
    reset_labels
    "counter" "" make_variable GLOBAL_VARIABLES .set = GLOBAL_VARIABLES

    List::new (List[Op]) = cai_ops
    OpKind::OpAssignInc (int) "counter" test_make_op_str cai_ops .push

    cai_ops make_compiler = cai_compiler
    List::new (List[Inst]) = cai_bytecode
    cai_bytecode cai_compiler compile_ops

    # Expected: LABEL, GLOBAL_GET, ADD, GLOBAL_SET
    "inc bytecode length" 4 cai_bytecode .length assert_eq
    "inc get" InstKind::InstGlobalGet (int) 1 cai_bytecode .get Inst::kind assert_eq
    "inc add" InstKind::InstAdd (int) 2 cai_bytecode .get Inst::kind assert_eq
    "inc set" InstKind::InstGlobalSet (int) 3 cai_bytecode .get Inst::kind assert_eq

    Map::new (Map[str Variable]) = GLOBAL_VARIABLES
}

