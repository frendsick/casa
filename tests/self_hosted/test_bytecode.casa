    dop_ops make_compiler = dop_compiler
    List::new (List[Inst]) = dop_bytecode
    dop_bytecode dop_compiler compile_ops

    "print_int inst" InstKind::InstPrintInt (int) 1 dop_bytecode .get Inst::kind assert_eq
    "print_str inst" InstKind::InstPrintStr (int) 2 dop_bytecode .get Inst::kind assert_eq
    "print_char inst" InstKind::InstPrintChar (int) 3 dop_bytecode .get Inst::kind assert_eq
    "print_cstr inst" InstKind::InstPrintCstr (int) 4 dop_bytecode .get Inst::kind assert_eq
    "print_bool inst" InstKind::InstPrintBool (int) 5 dop_bytecode .get Inst::kind assert_eq
}

fn test_compile_direct_ops_fn {
    "compile_direct_ops_fn" test_start
    reset_labels
    List::new (List[Op]) = dof_ops
    OpKind::OpFnExec (int) 0 test_make_op dof_ops .push
    OpKind::OpFnReturn (int) 0 test_make_op dof_ops .push

    dof_ops make_compiler = dof_compiler
    List::new (List[Inst]) = dof_bytecode
    dof_bytecode dof_compiler compile_ops

    "fn_exec inst" InstKind::InstFnExec (int) 1 dof_bytecode .get Inst::kind assert_eq
    "fn_return inst" InstKind::InstFnReturn (int) 2 dof_bytecode .get Inst::kind assert_eq
}

fn test_compile_push_array {
    "compile_push_array" test_start
    reset_labels

    # Create array items: [1, 2, 3]
    List::new (List[Op]) = cpa_items
    OpKind::OpPushInt (int) 1 test_make_op cpa_items .push
    OpKind::OpPushInt (int) 2 test_make_op cpa_items .push
    OpKind::OpPushInt (int) 3 test_make_op cpa_items .push

    # Create a PushArray op with the items list as value
    List::new (List[Op]) = cpa_ops
    make_test_location OpKind::OpPushArray (int) cpa_items (int) make_op cpa_ops .push

    cpa_ops make_compiler = cpa_compiler
    List::new (List[Inst]) = cpa_bytecode
    cpa_bytecode cpa_compiler compile_ops

    # Should contain: PUSH instructions for items, HEAP_ALLOC, STORE64, LABEL, JUMP, JUMP_NE
    # Check that HEAP_ALLOC is emitted
    0 = cpa_has_alloc
    0 = cpa_has_store
    0 = cpa_has_label
    0 = cpa_has_jump
    0 = cpa_has_jump_ne
    0 = cpa_i
    while cpa_i cpa_bytecode .length > do
        cpa_i cpa_bytecode .get Inst::kind = cpa_kind
        if InstKind::InstHeapAlloc (int) cpa_kind == then
            1 = cpa_has_alloc
        elif InstKind::InstStore64 (int) cpa_kind == then
            1 = cpa_has_store
        elif InstKind::InstLabel (int) cpa_kind == then
            1 = cpa_has_label
        elif InstKind::InstJump (int) cpa_kind == then
            1 = cpa_has_jump
        elif InstKind::InstJumpNe (int) cpa_kind == then
            1 = cpa_has_jump_ne
        fi
        1 += cpa_i
    done
    "array has heap_alloc" 1 cpa_has_alloc assert_eq
    "array has store64" 1 cpa_has_store assert_eq
    "array has label" 1 cpa_has_label assert_eq
    "array has jump" 1 cpa_has_jump assert_eq
    "array has jump_ne" 1 cpa_has_jump_ne assert_eq
}

fn test_compile_if_elif_else {
    "compile_if_elif_else" test_start
    reset_labels
    List::new (List[Op]) = tie_ops
    # if ... then ... elif ... then ... else ... fi
    OpKind::OpIfStart (int) 0 test_make_op tie_ops .push
    OpKind::OpIfCondition (int) 0 test_make_op tie_ops .push
    OpKind::OpIfElif (int) 0 test_make_op tie_ops .push
    OpKind::OpIfCondition (int) 0 test_make_op tie_ops .push
    OpKind::OpIfElse (int) 0 test_make_op tie_ops .push
    OpKind::OpIfEnd (int) 0 test_make_op tie_ops .push

    tie_ops make_compiler = tie_compiler
    List::new (List[Inst]) = tie_bytecode
    tie_bytecode tie_compiler compile_ops

    # Expected bytecode layout:
    # 0: LABEL (fn)
    # 1: JUMP_NE (if condition -> jump to elif label)
    # 2: JUMP (jump to fi from then-block)
    # 3: LABEL (elif label)
    # 4: JUMP_NE (elif condition -> jump to else label)
    # 5: JUMP (jump to fi from elif-block)
    # 6: LABEL (else label)
    # 7: LABEL (fi label)
    "elif bytecode length" 8 tie_bytecode .length assert_eq
    "elif fn label" InstKind::InstLabel (int) 0 tie_bytecode .get Inst::kind assert_eq
    "elif if jump_ne" InstKind::InstJumpNe (int) 1 tie_bytecode .get Inst::kind assert_eq
    "elif jump to fi" InstKind::InstJump (int) 2 tie_bytecode .get Inst::kind assert_eq
    "elif label" InstKind::InstLabel (int) 3 tie_bytecode .get Inst::kind assert_eq
    "elif cond jump_ne" InstKind::InstJumpNe (int) 4 tie_bytecode .get Inst::kind assert_eq
    "else jump to fi" InstKind::InstJump (int) 5 tie_bytecode .get Inst::kind assert_eq
    "else label" InstKind::InstLabel (int) 6 tie_bytecode .get Inst::kind assert_eq
    "fi label" InstKind::InstLabel (int) 7 tie_bytecode .get Inst::kind assert_eq
}

fn test_compile_fn_call {
    "compile_fn_call" test_start
    reset_labels

    # Register a function in GLOBAL_FUNCTIONS
    List::new (List[Op]) = cfc_fn_ops
    make_test_location cfc_fn_ops "greet" make_function = cfc_func
    "greet" cfc_func GLOBAL_FUNCTIONS .set = GLOBAL_FUNCTIONS

    List::new (List[Op]) = cfc_ops
    OpKind::OpFnCall (int) "greet" test_make_op_str cfc_ops .push

    cfc_ops make_compiler = cfc_compiler
    List::new (List[Inst]) = cfc_bytecode
    cfc_bytecode cfc_compiler compile_ops

    # Should have: LABEL, FN_CALL
    "fn_call bytecode length" 2 cfc_bytecode .length assert_eq
    "fn_call inst kind" InstKind::InstFnCall (int) 1 cfc_bytecode .get Inst::kind assert_eq

    # Clean up
    Map::new (Map[str Function]) = GLOBAL_FUNCTIONS
}

fn test_compile_fn_push {
    "compile_fn_push" test_start
    reset_labels

    # Register a function in GLOBAL_FUNCTIONS with has_deferred_methods = 0
    List::new (List[Op]) = cfp_fn_ops
    OpKind::OpPushInt (int) 1 test_make_op cfp_fn_ops .push
    make_test_location cfp_fn_ops "adder" make_function = cfp_func
    "adder" cfp_func GLOBAL_FUNCTIONS .set = GLOBAL_FUNCTIONS

    List::new (List[Op]) = cfp_ops
    OpKind::OpFnPush (int) "adder" test_make_op_str cfp_ops .push

    cfp_ops make_compiler = cfp_compiler
    List::new (List[Inst]) = cfp_bytecode
    cfp_bytecode cfp_compiler compile_ops

    # FnPush should emit FN_PUSH instruction with function name
    # Find FN_PUSH instruction in bytecode
    "fn_push has instrs" 0 cfp_bytecode .length != assert_true

    # Clean up
    Map::new (Map[str Function]) = GLOBAL_FUNCTIONS
}

