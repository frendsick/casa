fn test_op_index_to_label_stability {
    "op_index_to_label_stability" test_start
    reset_labels
    42 op_index_to_label = stable_first
    42 op_index_to_label = stable_second
    "same index same label" stable_first stable_second assert_eq
    99 op_index_to_label = other_label
    "different index different label" stable_first other_label != assert_true
}

fn test_compile_if_block {
    "compile_if_block" test_start
    reset_labels
    List::new (List[Op]) = tib_ops
    OpKind::OpIfStart (int) 0 test_make_op tib_ops .push
    OpKind::OpIfCondition (int) 0 test_make_op tib_ops .push
    OpKind::OpIfEnd (int) 0 test_make_op tib_ops .push

    "ops has 3 elements" 3 tib_ops .length assert_eq
    "op 0 is if_start" OpKind::OpIfStart (int) 0 tib_ops .get Op::kind assert_eq
    "op 2 is if_end" OpKind::OpIfEnd (int) 2 tib_ops .get Op::kind assert_eq

    tib_ops make_compiler = tib_compiler
    List::new (List[Inst]) = tib_bytecode
    tib_bytecode tib_compiler compile_ops

    # Expected: LABEL, JUMP_NE(end_label), LABEL(end_label)
    "if block bytecode length" 3 tib_bytecode .length assert_eq
    "if block has label" InstKind::InstLabel (int) 0 tib_bytecode .get Inst::kind assert_eq
    "if condition jump_ne" InstKind::InstJumpNe (int) 1 tib_bytecode .get Inst::kind assert_eq
    "if end label" InstKind::InstLabel (int) 2 tib_bytecode .get Inst::kind assert_eq
}

fn test_compile_while_block {
    "compile_while_block" test_start
    reset_labels
    List::new (List[Op]) = twb_ops
    OpKind::OpWhileStart (int) 0 test_make_op twb_ops .push
    OpKind::OpWhileCondition (int) 0 test_make_op twb_ops .push
    OpKind::OpWhileEnd (int) 0 test_make_op twb_ops .push

    twb_ops make_compiler = twb_compiler
    List::new (List[Inst]) = twb_bytecode
    twb_bytecode twb_compiler compile_ops

    # Expected: LABEL(fn), LABEL(start), JUMP_NE(end), JUMP(start), LABEL(end)
    "while block bytecode length" 5 twb_bytecode .length assert_eq
    "while fn label" InstKind::InstLabel (int) 0 twb_bytecode .get Inst::kind assert_eq
    "while start label" InstKind::InstLabel (int) 1 twb_bytecode .get Inst::kind assert_eq
    "while condition jump_ne" InstKind::InstJumpNe (int) 2 twb_bytecode .get Inst::kind assert_eq
    "while end jump" InstKind::InstJump (int) 3 twb_bytecode .get Inst::kind assert_eq
    "while end label" InstKind::InstLabel (int) 4 twb_bytecode .get Inst::kind assert_eq
}

