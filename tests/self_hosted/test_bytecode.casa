include "../../self_hosted/common.casa"
include "../../self_hosted/error.casa"
include "../../lib/test.casa"

# ============================================================================
# Stub globals normally provided by parser.casa
# ============================================================================
Map::new (Map[str Function]) = GLOBAL_FUNCTIONS
Map::new (Map[str Variable]) = GLOBAL_VARIABLES
Map::new (Map[str CasaEnum]) = GLOBAL_ENUMS
Map::new (Map[str CasaStruct]) = GLOBAL_STRUCTS

include "../../self_hosted/bytecode.casa"

# ============================================================================
# Test helpers
# ============================================================================

fn make_test_location -> Location {
    # make_location file:str offset:int length:int
    # param1=file, param2=offset, param3=length -> length offset file make_location
    1 0 "test.casa" make_location
}

# Helper to create an op with int value
# make_op value:int kind:int location:Location
# param1=value, param2=kind, param3=location
fn test_make_op value:int kind:int -> Op {
    make_test_location kind value make_op
}

# Helper to create an op with str value
# make_op_str value:str kind:int location:Location
# param1=value, param2=kind, param3=location
fn test_make_op_str value:str kind:int -> Op {
    make_test_location kind value make_op_str
}

# Helper to create an annotated op
# make_op_annotated value:int kind:int location:Location annotation:str
# param1=value, param2=kind, param3=location, param4=annotation
fn test_make_op_annotated value:int kind:int annotation:str -> Op {
    annotation make_test_location kind value make_op_annotated
}

# ============================================================================
# Tests
# ============================================================================

fn test_new_label {
    "new_label" test_start
    reset_labels
    new_label = first_label
    "first label is 0" 0 first_label assert_eq
    new_label = second_label
    "second label is 1" 1 second_label assert_eq
    new_label = third_label
    "third label is 2" 2 third_label assert_eq
}

fn test_intern_string {
    "intern_string" test_start
    List::new (List[Op]) = is_ops
    is_ops make_compiler = is_compiler
    # intern_string compiler:BytecodeCompiler value:str
    # param1=compiler, param2=value -> value compiler intern_string
    "first string index" 0 "hello" is_compiler intern_string assert_eq
    "same string same index" 0 "hello" is_compiler intern_string assert_eq
    "second string index" 1 "world" is_compiler intern_string assert_eq
    "table has two entries" 2 is_compiler BytecodeCompiler::string_table .length assert_eq
}

fn test_intern_constant {
    "intern_constant" test_start
    List::new (List[Op]) = ic_ops
    ic_ops make_compiler = ic_compiler
    "first constant index" 0 "MY_CONST" ic_compiler intern_constant assert_eq
    "same constant same index" 0 "MY_CONST" ic_compiler intern_constant assert_eq
    "second constant index" 1 "OTHER" ic_compiler intern_constant assert_eq
}

fn test_compile_push_int {
    "compile_push_int" test_start
    reset_labels
    List::new (List[Op]) = cpi_ops
    OpKind::OpPushInt (int) 42 test_make_op cpi_ops .push

    cpi_ops make_compiler = cpi_compiler
    List::new (List[Inst]) = cpi_bytecode
    # compile_ops compiler:BytecodeCompiler bytecode:List[Inst]
    # param1=compiler, param2=bytecode -> bytecode compiler compile_ops
    cpi_bytecode cpi_compiler compile_ops

    # Should have: LABEL, PUSH(42)
    "push_int bytecode length" 2 cpi_bytecode .length assert_eq
    "push_int label kind" InstKind::InstLabel (int) 0 cpi_bytecode .get Inst::kind assert_eq
    "push_int inst kind" InstKind::InstPush (int) 1 cpi_bytecode .get Inst::kind assert_eq
    "push_int value" 42 1 cpi_bytecode .get Inst::int_arg assert_eq
}

fn test_compile_push_bool {
