    "push_bool inst kind" InstKind::InstPush (int) 1 cpb_bytecode .get Inst::kind assert_eq
    "push_bool true value" 1 1 cpb_bytecode .get Inst::int_arg assert_eq
}

fn test_compile_push_str {
    "compile_push_str" test_start
