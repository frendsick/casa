    # Expected: LABEL, GLOBAL_GET, ADD, GLOBAL_SET
    "inc bytecode length" 4 cai_bytecode .length assert_eq
    "inc get" InstKind::InstGlobalGet (int) 1 cai_bytecode .get Inst::kind assert_eq
    "inc add" InstKind::InstAdd (int) 2 cai_bytecode .get Inst::kind assert_eq
    "inc set" InstKind::InstGlobalSet (int) 3 cai_bytecode .get Inst::kind assert_eq

    Map::new (Map[str Variable]) = GLOBAL_VARIABLES
}

