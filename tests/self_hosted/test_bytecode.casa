fn test_compile_direct_ops {
    "compile_direct_ops" test_start
    reset_labels
    List::new (List[Op]) = cdo_ops
    OpKind::OpAdd (int) 0 test_make_op cdo_ops .push
    OpKind::OpSub (int) 0 test_make_op cdo_ops .push
    OpKind::OpDup (int) 0 test_make_op cdo_ops .push
    OpKind::OpDrop (int) 0 test_make_op cdo_ops .push

    cdo_ops make_compiler = cdo_compiler
    List::new (List[Inst]) = cdo_bytecode
    cdo_bytecode cdo_compiler compile_ops

    # Index 0 is label
    "add inst" InstKind::InstAdd (int) 1 cdo_bytecode .get Inst::kind assert_eq
    "sub inst" InstKind::InstSub (int) 2 cdo_bytecode .get Inst::kind assert_eq
    "dup inst" InstKind::InstDup (int) 3 cdo_bytecode .get Inst::kind assert_eq
    "drop inst" InstKind::InstDrop (int) 4 cdo_bytecode .get Inst::kind assert_eq
}

fn test_compile_variable_assign_and_push {
    "compile_variable_assign_and_push" test_start
    reset_labels

    # Set up a global variable
    # Map.set self:Map[K V] value:V key:K -> param1=self, param2=value, param3=key
    # key value self .set
    "x" "" make_variable GLOBAL_VARIABLES .set = GLOBAL_VARIABLES

    List::new (List[Op]) = cva_ops
    OpKind::OpAssignVar (int) "x" test_make_op_str cva_ops .push
    OpKind::OpPushVar (int) "x" test_make_op_str cva_ops .push

    cva_ops make_compiler = cva_compiler
    List::new (List[Inst]) = cva_bytecode
    cva_bytecode cva_compiler compile_ops

    # Index 0 is label, 1 is GLOBAL_SET, 2 is GLOBAL_GET
    "assign var kind" InstKind::InstGlobalSet (int) 1 cva_bytecode .get Inst::kind assert_eq
    "push var kind" InstKind::InstGlobalGet (int) 2 cva_bytecode .get Inst::kind assert_eq

    # Clean up
    Map::new (Map[str Variable]) = GLOBAL_VARIABLES
}

fn test_compile_local_variable {
    "compile_local_variable" test_start
    reset_labels

    # Create a function with a variable
    List::new (List[Op]) = clv_fn_ops
    OpKind::OpAssignVar (int) "y" test_make_op_str clv_fn_ops .push
    OpKind::OpPushVar (int) "y" test_make_op_str clv_fn_ops .push

    # make_function name:str ops:List[Op] location:Location
    # param1=name, param2=ops, param3=location
    make_test_location clv_fn_ops "test_fn" make_function = clv_func
    "y" make_variable clv_func Function::variables .push

    List::new (List[Inst]) = clv_bytecode
    # make_compiler_with_tables ops:List[Op] function:int string_table:List[str] constants_table:List[str]
    # param1=ops, param2=function, param3=string_table, param4=constants_table
    # make_compiler_with_tables ops:List[Op] function:int string_table:List[str] constants_table:List[str]
    # param1=ops, param2=function, param3=string_table, param4=constants_table
    # push order: constants_table, string_table, function, ops
    List::new (List[str]) List::new (List[str]) clv_func (int) clv_fn_ops make_compiler_with_tables = clv_compiler
    clv_bytecode clv_compiler compile_ops

    # Index 0 is label, 1 is LOCAL_SET, 2 is LOCAL_GET
    "local assign kind" InstKind::InstLocalSet (int) 1 clv_bytecode .get Inst::kind assert_eq
    "local assign index" 0 1 clv_bytecode .get Inst::int_arg assert_eq
    "local push kind" InstKind::InstLocalGet (int) 2 clv_bytecode .get Inst::kind assert_eq
    "local push index" 0 2 clv_bytecode .get Inst::int_arg assert_eq
}

