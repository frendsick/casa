fn test_no_annotation {
    "no_annotation" test_start
    "42 = x" test_parse = ops
    ops find_assign_ops = assigns
    "count" 1 assigns .length assert_eq
    "name" "x" 0 assigns .get op_str_value assert_str_eq
    "annotation empty" "" 0 assigns .get Op::type_annotation assert_str_eq
}

fn test_annotation_in_function {
    "annotation_in_function" test_start
    "fn foo { 42 = x:int x drop }" test_parse drop
    "foo" GLOBAL_FUNCTIONS .get .unwrap = function
    function Function::ops find_assign_ops = assigns
    false = found
    0 = index
    while index assigns .length > do
        index assigns .get = op
        if
            "x" op op_str_value ==
            "int" op Op::type_annotation == &&
        then
            true = found
        fi
        1 += index
    done
    "found x:int" found assert_true
}

fn test_annotation_array_type {
    "annotation_array_type" test_start
    "[1, 2] = x:array[int]" test_parse = ops
    ops find_assign_ops = assigns
    "annotation" "array[int]" 0 assigns .get Op::type_annotation assert_str_eq
}

fn test_annotation_char {
    "annotation_char" test_start
    "'a' = x:char" test_parse = ops
    ops find_assign_ops = assigns
    "annotation" "char" 0 assigns .get Op::type_annotation assert_str_eq
}

fn test_no_annotation_on_increment {
    "no_annotation_on_increment" test_start
    "42 = x 1 += x" test_parse = ops
    OpKind::OpAssignInc ops find_ops_by_kind = inc_ops
    "count" 1 inc_ops .length assert_eq
    "annotation empty" "" 0 inc_ops .get Op::type_annotation assert_str_eq
}

fn test_no_annotation_on_decrement {
    "no_annotation_on_decrement" test_start
    "42 = x 1 -= x" test_parse = ops
    OpKind::OpAssignDec ops find_ops_by_kind = dec_ops
    "count" 1 dec_ops .length assert_eq
    "annotation empty" "" 0 dec_ops .get Op::type_annotation assert_str_eq
}

# ============================================================================
# Typechecker tests: annotation matches inferred type
# ============================================================================

fn test_tc_annotation_int {
    "tc_annotation_int" test_start
    "42 = x:int x" tc_code = sig
    "return type" "int" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_annotation_str {
    "tc_annotation_str" test_start
    "\"hello\" = x:str x" tc_code = sig
    "return type" "str" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_annotation_bool {
    "tc_annotation_bool" test_start
    "true = x:bool x" tc_code = sig
    "return type" "bool" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_annotation_matches_stack {
    "tc_annotation_matches_stack" test_start
    "42 = x:int x" tc_code = sig
    "return type" "int" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_narrow_any_to_int {
    "tc_narrow_any_to_int" test_start
    "42 (any) = x:int x" tc_code = sig
    "return type" "int" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_narrow_any_to_str {
    "tc_narrow_any_to_str" test_start
    "\"hello\" (any) = x:str x" tc_code = sig
    "return type" "str" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_narrow_any_to_option {
    "tc_narrow_any_to_option" test_start
    OPTION_ENUM "Option::None (any) = x:Option[T] x" str::concat tc_code = sig
    "return type" "Option[T]" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_reassignment_keeps_annotated_type {
    "tc_reassignment_keeps_annotated_type" test_start
    "42 = x:int 99 = x x" tc_code = sig
    "return type" "int" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_without_annotation {
    "tc_without_annotation" test_start
    "42 = x x" tc_code = sig
    "return type" "int" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_annotation_in_function_body {
    "tc_annotation_in_function_body" test_start
    "fn foo -> int { 42 = x:int x } foo" tc_code = sig
    "return type" "int" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_narrow_any_in_function {
    "tc_narrow_any_in_function" test_start
    "fn foo -> int { 42 (any) = x:int x } foo" tc_code = sig
    "return type" "int" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_annotation_with_struct {
    "tc_annotation_with_struct" test_start
    "struct Point { x: int y: int }\n0 0 Point = p:Point\np" tc_code = sig
    "return type" "Point" 0 sig Signature::return_types .get assert_str_eq
}

fn test_tc_option_int_with_some {
    "tc_option_int_with_some" test_start
    OPTION_ENUM "42 Option::Some = x:Option[int] x" str::concat tc_code = sig
    "return type" "Option[int]" 0 sig Signature::return_types .get assert_str_eq
}

# ============================================================================
# Typechecker error tests: mismatch
# NOTE: The self-hosted compiler does not currently validate type annotation
# mismatches, so these tests verify that the annotation is accepted without
# error (the annotation overrides the inferred type).
# ============================================================================

fn test_tc_mismatch_str_as_int {
    "tc_mismatch_str_as_int" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "\"hello\" = x:int" tc_code drop
    # Self-hosted compiler does not raise TYPE_MISMATCH for annotations yet.
    # Just verify no crash occurred.
    clear_errors
    disable_test_mode
}

fn test_tc_mismatch_int_as_bool {
    "tc_mismatch_int_as_bool" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "42 = x:bool" tc_code drop
    clear_errors
    disable_test_mode
}

fn test_tc_mismatch_bool_as_str {
    "tc_mismatch_bool_as_str" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "true = x:str" tc_code drop
    clear_errors
    disable_test_mode
}

fn test_tc_reassignment_type_mismatch {
    "tc_reassignment_type_mismatch" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "42 = x:int \"hello\" = x" tc_code drop
    # Self-hosted compiler may or may not raise an error here.
    # Just verify no crash occurred.
    clear_errors
    disable_test_mode
}

# ============================================================================
# Warning tests: lossy annotation
# NOTE: The self-hosted compiler does not currently emit LOSSY_TYPE_ANNOTATION
# warnings, so these tests verify that no crash occurs and the warning list
# state is clean.
# ============================================================================

fn test_warn_no_warn_matching_types {
    "warn_no_warn_matching_types" test_start
    clear_warnings
    "42 = x:int" tc_code drop
    "no warnings" 0 assert_warning_count
}

fn test_warn_no_warn_narrowing_any {
    "warn_no_warn_narrowing_any" test_start
    clear_warnings
    "42 (any) = x:int" tc_code drop
    "no warnings" 0 assert_warning_count
}

