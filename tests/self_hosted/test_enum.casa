fn test_is_type_mismatch_raises {
    "is_type_mismatch_raises" test_start
    enable_test_mode
    clear_global_state
    clear_errors
    "enum Color { Red Green Blue }\n42 Color::Red is" tc_enum drop
    "has errors" assert_has_errors
    clear_errors
    disable_test_mode
}

