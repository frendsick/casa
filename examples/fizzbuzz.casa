1 = index
30 = last

while index last >= do
    index fizzbuzz
    1 += index
done

fn fizzbuzz number:int {
    number 3 % 0 == = fizz
    number 5 % 0 == = buzz

    if fizz buzz && then
        "FizzBuzz\n" print
    elif fizz then
        "Fizz\n" print
    elif buzz then
        "Buzz\n" print
    else
        number print '\n' print
    fi
}
